}

function doExportXlsx(inverse, baseColorHex) {
  const rows = inverse ? getInverseRows() : filteredRows;
  if (!rows.length) { toast('❌ Sem dados para exportar', 'err'); return; }

  const now      = new Date();  // hora exata agora
  const today    = new Date(); today.setHours(0,0,0,0);
  const tomorrow = new Date(today); tomorrow.setDate(tomorrow.getDate()+1);

  // Deriva cores a partir da cor escolhida
  const headerBg  = baseColorHex;
  const rowOdd    = lightenHex(baseColorHex, 0.88);  // muito claro
  const rowEven   = lightenHex(baseColorHex, 0.75);  // levemente mais escuro

  const wb = XLSX.utils.book_new();
  const byArea = {};
  rows.forEach(({ __area, ...row }) => {
    if (!byArea[__area]) byArea[__area] = [];
    byArea[__area].push({ row, isFora: isSiteForaRow(row) });
  });

  ALL_AREAS.forEach(area => {
    if (!byArea[area]?.length) return;
    const entries = byArea[area];
    const cols    = EXPORT_REPORT_COLS;
    const ws      = {};

    // ── Cabeçalho ──
    cols.forEach((col, C) => {
      ws[XLSX.utils.encode_cell({ r: 0, c: C })] = {
        v: col.label, t: 's',
        s: {
          font:      { bold: true, color: { rgb: 'FFFFFF' }, sz: 11, name: 'Arial' },
          fill:      { patternType: 'solid', fgColor: { rgb: headerBg } },
          alignment: { horizontal: 'center', vertical: 'center', wrapText: false },
          border:    makeBorder('FFFFFF', 'medium'),
        }
      };
    });

    // ── Dados ──
    entries.forEach(({ row, isFora }, rowIdx) => {
      const R       = rowIdx + 1;
      const slaDate  = parseSLADate(row['Fim SLA']);
      const isPast   = slaDate && slaDate < now;                              // já venceu (hora exata)
      const isToday  = slaDate && !isPast && slaDate < tomorrow;              // vence hoje ainda
      const isSoon   = slaDate && !isPast && (slaDate - now) < 4*3600*1000;  // vence em menos de 4h

      // Linha site fora: fundo avermelhado em toda a linha
      const lineBg   = isFora ? 'FFCDD2' : 'FFFFFF';
      const lineFont = isFora ? '7F0000' : '1A1A2E';

      cols.forEach((col, C) => {
        const isSlCol  = col.header === 'Fim SLA';
        const isObsCol = col.header === 'OBS';
        const rowTsk   = String(row['TSK'] ?? '').trim();
        const rowObs   = obsMap[rowTsk] || '';
        const isNormRow = rowObs === 'Normalizado';
        const rawVal   = isObsCol ? rowObs : (row[col.header] ?? '');
        const val      = String(rawVal);

        // Linha normalizado → fundo verde em toda a linha
        let cellBg   = isNormRow ? 'C8F5DC' : lineBg;
        let cellFont = isNormRow ? '1B5E20' : lineFont;
        let cellBold = isNormRow;
        let borderColor = isNormRow ? '66BB6A' : 'C0C8D8';

        // Só a célula Fim SLA recebe cor especial (exceto normalizado e site fora)
        if (isSlCol && !isFora && !isNormRow) {
          if (isPast)                  { cellBg = 'FFCDD2'; cellFont = 'B71C1C'; cellBold = false; } // vencido — vermelho claro
          if (isSoon)                  { cellBg = 'C62828'; cellFont = 'FFFFFF'; cellBold = true;  } // menos de 4h — vermelho forte
          if (isToday && !isSoon)      { cellBg = 'E53935'; cellFont = 'FFFFFF'; cellBold = true;  } // vence hoje >4h — vermelho médio
        }

        if (isObsCol && !isNormRow) borderColor = '888888';

        ws[XLSX.utils.encode_cell({ r: R, c: C })] = {
          v: val, t: 's',
          s: {
            font:      { sz: 10, color: { rgb: cellFont }, name: 'Arial', bold: cellBold },
            fill:      { patternType: 'solid', fgColor: { rgb: cellBg } },
            alignment: { vertical: 'center', horizontal: isObsCol ? 'left' : 'center' },
            border:    makeBorder(borderColor, 'thin'),
          }
        };
      });
    });

    const totalRows = entries.length + 1;
    ws['!ref']  = XLSX.utils.encode_range({ s:{r:0,c:0}, e:{r:totalRows-1,c:cols.length-1} });

    // Largura automática: máximo de chars em cada coluna (header + dados), com mínimo e máximo
    const colWidths = cols.map((col, C) => {
      let max = col.label.length + 2; // começa pelo tamanho do header
      entries.forEach(({ row }) => {
        const v = String(col.header === 'OBS' ? (obsMap[String(row['TSK'] ?? '').trim()] || '') : (row[col.header] ?? ''));
        if (v.length > max) max = v.length;
      });
      return { wch: Math.min(Math.max(max + 2, col.width), 60) };
    });
    ws['!cols'] = colWidths;

    // Altura automática das linhas baseada no conteúdo mais longo de cada linha
    const rowHeights = [{ hpt: 30 }]; // cabeçalho
    entries.forEach(({ row }) => {
      let maxLines = 1;
      cols.forEach(col => {
        const v = String(col.header === 'OBS' ? (obsMap[String(row['TSK'] ?? '').trim()] || '') : (row[col.header] ?? ''));
        // Conta quebras de linha e estima linhas pelo comprimento vs largura da coluna
        const colW = colWidths[cols.indexOf(col)].wch;
        const lines = Math.max(1, Math.ceil(v.length / Math.max(colW, 1)));
        if (lines > maxLines) maxLines = lines;
      });
      rowHeights.push({ hpt: Math.min(Math.max(maxLines * 14, 18), 80) });
    });
    ws['!rows'] = rowHeights;

    XLSX.utils.book_append_sheet(wb, ws, SHEET_NAMES[area]);
  });

  const date  = new Date().toLocaleDateString('pt-BR').replace(/\//g, '-');
  const sufx  = inverse ? '_NAO_SELECIONADOS' : '_filtrado';
  const fname = `REPORT_CSM_FIXA${sufx}_${date}.xlsx`;
  XLSX.writeFile(wb, fname);
  toast(`⬇ ${rows.length} linha${rows.length!==1?'s':''} exportadas → ${fname}`, 'ok');
}


