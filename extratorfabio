
<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CSM FIXA — Extrator de Fila</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');

:root {
  --bg: #f0f2f5;
  --white: #ffffff;
  --border: #e2e4e9;
  --border2: #c8cbd4;
  --accent: #0052cc;
  --accent-h: #0747a6;
  --accent-light: #deebff;
  --green: #006644;
  --green-light: #e3fcef;
  --green-btn: #00875a;
  --red: #bf2600;
  --red-light: #ffebe6;
  --orange: #ff8b00;
  --orange-light: #fffae6;
  --yellow: #ff991f;
  --text: #172b4d;
  --muted: #6b778c;
  --subtle: #97a0af;
  --tag: #dfe1e6;
  --c-baixada: #0052cc;
  --c-oeste: #00875a;
  --c-grj: #6554c0;
  --c-interior: #b85c00;
  --c-es: #006b75;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'IBM Plex Sans', sans-serif; font-size: 14px; min-height: 100vh; }

/* TOPBAR */
.topbar {
  background: #0747a6; padding: 0 24px; height: 52px;
  display: flex; align-items: center; gap: 12px;
  position: sticky; top: 0; z-index: 200;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}
.topbar-logo { display: flex; align-items: center; gap: 10px; color: #fff; font-weight: 700; font-size: 15px; letter-spacing: 0.3px; }
.dot { width: 8px; height: 8px; background: #4fc3f7; border-radius: 50%; animation: blink 2s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.topbar-right { margin-left: auto; display: flex; align-items: center; gap: 16px; }
.topbar-hint { font-size: 11px; color: rgba(255,255,255,0.55); font-family: 'IBM Plex Mono', monospace; }

/* TAB NAV */
.tab-nav { display: flex; gap: 2px; background: rgba(0,0,0,0.2); border-radius: 6px; padding: 3px; }
.tab-btn {
  padding: 5px 14px; border-radius: 4px; border: none; cursor: pointer;
  font-family: 'IBM Plex Sans', sans-serif; font-size: 12px; font-weight: 600;
  color: rgba(255,255,255,0.65); background: transparent; transition: all 0.15s;
}
.tab-btn.active { background: #fff; color: var(--accent); }
.tab-btn:hover:not(.active) { color: #fff; background: rgba(255,255,255,0.15); }

/* LAYOUT */
.layout { display: flex; min-height: calc(100vh - 52px); }

/* SIDEBAR */
.sidebar {
  width: 310px; flex-shrink: 0; background: var(--white);
  border-right: 1px solid var(--border); padding: 20px 16px;
  display: flex; flex-direction: column; gap: 20px;
  position: sticky; top: 52px; height: calc(100vh - 52px); overflow-y: auto;
}
.sec-label {
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  text-transform: uppercase; color: var(--subtle); margin-bottom: 10px;
}

/* UPLOAD SLOTS */
.slots { display: flex; flex-direction: column; gap: 8px; }
.slot {
  border: 2px dashed var(--border2); border-radius: 8px;
  padding: 10px 12px; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; gap: 10px; position: relative; user-select: none;
}
.slot:hover:not(.loaded) { border-color: var(--accent); background: var(--accent-light); }
.slot.drag-over { border-color: var(--accent); background: var(--accent-light); transform: scale(1.01); }
.slot.loaded { cursor: default; border-style: solid; }
.slot.loaded.B { border-color: var(--c-baixada); background: #e8f0fe; }
.slot.loaded.O { border-color: var(--c-oeste); background: var(--green-light); }
.slot.loaded.G { border-color: var(--c-grj); background: #f0ecff; }
.slot.loaded.I { border-color: var(--c-interior); background: #fff3e0; }
.slot.loaded.E { border-color: var(--c-es); background: #e0f5f5; }
.slot-ico { font-size: 18px; flex-shrink: 0; }
.slot-body { flex: 1; min-width: 0; }
.slot-title { font-size: 12px; font-weight: 700; }
.slot-title.B { color: var(--c-baixada); }
.slot-title.O { color: var(--c-oeste); }
.slot-title.G { color: var(--c-grj); }
.slot-title.I { color: var(--c-interior); }
.slot-title.E { color: var(--c-es); }
.slot-sub { font-size: 10px; color: var(--muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.slot-x {
  flex-shrink: 0; background: none; border: none; color: var(--subtle);
  cursor: pointer; font-size: 13px; padding: 3px 6px; border-radius: 4px;
  transition: all 0.15s; line-height: 1;
}
.slot-x:hover { color: var(--red); background: rgba(191,38,0,0.08); }

/* FILTROS */
.filter-controls { display: flex; gap: 6px; margin-bottom: 8px; }
.filter-ctrl-btn {
  flex: 1; padding: 5px 8px; border-radius: 4px; border: 1px solid var(--border2);
  background: var(--bg); font-size: 10px; font-weight: 600; cursor: pointer;
  color: var(--muted); transition: all 0.15s; font-family: 'IBM Plex Sans', sans-serif;
}
.filter-ctrl-btn:hover { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

.filter-list { display: flex; flex-direction: column; gap: 4px; }
.filter-item {
  display: flex; align-items: center; gap: 8px; padding: 8px 10px;
  border-radius: 6px; cursor: pointer; transition: background 0.15s; user-select: none;
  border: 1px solid transparent;
}
.filter-item:hover { background: var(--bg); }
.filter-item.on { background: var(--accent-light); border-color: #b3d0ff; }
.filter-item input[type=checkbox] { accent-color: var(--accent); width: 15px; height: 15px; cursor: pointer; flex-shrink: 0; }
.filter-name { font-size: 11px; font-family: 'IBM Plex Mono', monospace; font-weight: 500; flex: 1; line-height: 1.4; }
.filter-badge { font-size: 10px; background: var(--tag); color: var(--muted); border-radius: 10px; padding: 2px 8px; font-family: 'IBM Plex Mono', monospace; flex-shrink: 0; }
.filter-item.on .filter-badge { background: var(--accent); color: #fff; }

/* EXTRA FILTERS */
.extra-filters { display: flex; flex-direction: column; gap: 8px; }
.extra-filter-row { display: flex; flex-direction: column; gap: 4px; }
.extra-filter-label { font-size: 10px; font-weight: 700; color: var(--subtle); text-transform: uppercase; letter-spacing: 0.5px; }
.extra-filter-chips { display: flex; flex-wrap: wrap; gap: 4px; }
.chip {
  padding: 3px 10px; border-radius: 20px; font-size: 10px; font-weight: 600;
  border: 1px solid var(--border2); background: var(--bg); color: var(--muted);
  cursor: pointer; transition: all 0.15s; font-family: 'IBM Plex Mono', monospace;
}
.chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
.chip.on { background: var(--accent); border-color: var(--accent); color: #fff; }

/* BTNS */
.btn-row { display: flex; flex-direction: column; gap: 8px; }
.btn {
  display: flex; align-items: center; justify-content: center; gap: 7px;
  padding: 10px 16px; border-radius: 5px; font-family: 'IBM Plex Sans', sans-serif;
  font-size: 13px; font-weight: 600; cursor: pointer; border: none;
  transition: all 0.15s; width: 100%;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover:not(:disabled) { background: var(--accent-h); }
.btn-primary:disabled { opacity: 0.38; cursor: not-allowed; }
.btn-export { background: var(--green-btn); color: #fff; }
.btn-export:hover:not(:disabled) { background: var(--green); }
.btn-export:disabled { opacity: 0.38; cursor: not-allowed; }
.btn-inverse { background: var(--orange); color: #fff; }
.btn-inverse:hover:not(:disabled) { background: #e07b00; }
.btn-inverse:disabled { opacity: 0.38; cursor: not-allowed; }

/* MAIN */
.main { flex: 1; padding: 20px; min-width: 0; display: flex; flex-direction: column; gap: 16px; }
.tab-panel { display: none; flex-direction: column; gap: 16px; flex: 1; }
.tab-panel.active { display: flex; }

/* STATS */
.stats { display: flex; gap: 12px; flex-wrap: wrap; }
.stat {
  background: var(--white); border: 1px solid var(--border); border-radius: 8px;
  padding: 12px 18px; min-width: 120px;
}
.stat-val { font-size: 24px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; color: var(--accent); line-height: 1; }
.stat-lbl { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }
.stat.g .stat-val { color: var(--green-btn); }
.stat.o .stat-val { color: var(--orange); }
.stat.r .stat-val { color: var(--red); }

/* SEARCH BAR */
.search-bar {
  display: flex; align-items: center; gap: 8px;
  background: var(--white); border: 1px solid var(--border); border-radius: 6px;
  padding: 8px 12px;
}
.search-bar input {
  flex: 1; border: none; outline: none; font-family: 'IBM Plex Sans', sans-serif;
  font-size: 13px; color: var(--text); background: transparent;
}
.search-bar input::placeholder { color: var(--subtle); }
.search-icon { color: var(--subtle); font-size: 14px; }
.search-clear {
  background: none; border: none; color: var(--subtle); cursor: pointer;
  font-size: 13px; padding: 2px 5px; border-radius: 3px; transition: all 0.15s;
}
.search-clear:hover { color: var(--red); }

/* TABLE CARD */
.tcard { background: var(--white); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; flex: 1; display: flex; flex-direction: column; }
.ttoolbar { padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; flex-wrap: wrap; background: #fafbfc; }
.ttitle { font-weight: 700; font-size: 13px; }
.rows-badge { background: var(--accent-light); color: var(--accent); border-radius: 20px; padding: 2px 10px; font-size: 11px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; }
.inverse-badge { background: var(--orange-light); color: var(--orange); border-radius: 20px; padding: 2px 10px; font-size: 10px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; display: none; }
.inverse-badge.show { display: inline-block; }
.area-pill { padding: 2px 10px; border-radius: 20px; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
.area-pill.B { background: #e8f0fe; color: var(--c-baixada); }
.area-pill.O { background: var(--green-light); color: var(--c-oeste); }
.area-pill.G { background: #f0ecff; color: var(--c-grj); }
.area-pill.I { background: #fff3e0; color: var(--c-interior); }
.area-pill.E { background: #e0f5f5; color: var(--c-es); }

.tscroll { overflow: auto; flex: 1; max-height: calc(100vh - 320px); }
table { width: 100%; border-collapse: collapse; font-size: 12px; white-space: nowrap; }
thead { position: sticky; top: 0; z-index: 5; }
th {
  background: #f4f5f7; padding: 8px 12px; text-align: left; font-size: 10px;
  font-weight: 700; letter-spacing: 0.5px; color: var(--muted); border-bottom: 2px solid var(--border);
  text-transform: uppercase; cursor: pointer; user-select: none; white-space: nowrap;
}
th:hover { background: #eaecf0; color: var(--text); }
th.key-col { color: var(--accent); background: var(--accent-light); }
th .sort-arrow { margin-left: 4px; opacity: 0.4; }
th.sort-asc .sort-arrow, th.sort-desc .sort-arrow { opacity: 1; color: var(--accent); }
td { padding: 7px 12px; border-bottom: 1px solid var(--border); color: var(--text); max-width: 220px; overflow: hidden; text-overflow: ellipsis; vertical-align: middle; }
tr:last-child td { border-bottom: none; }
tr:hover td { background: #f8f9fa; }
tr.sla-vencido td { background: #fff0ed; }
tr.sla-vencido:hover td { background: #ffe4de; }
tr.sla-alerta td { background: #fffae6; }
tr.sla-alerta:hover td { background: #fff3cc; }
.area-cell { font-weight: 700; font-size: 10px; letter-spacing: 0.5px; padding: 2px 7px; border-radius: 3px; display: inline-block; text-transform: uppercase; }
.area-cell.B { background: #e8f0fe; color: var(--c-baixada); }
.area-cell.O { background: var(--green-light); color: var(--c-oeste); }
.area-cell.G { background: #f0ecff; color: var(--c-grj); }
.area-cell.I { background: #fff3e0; color: var(--c-interior); }
.area-cell.E { background: #e0f5f5; color: var(--c-es); }
.regra-cell { font-family: 'IBM Plex Mono', monospace; font-size: 10px; background: var(--accent-light); color: var(--accent); padding: 2px 7px; border-radius: 3px; display: inline-block; max-width: 200px; overflow: hidden; text-overflow: ellipsis; font-weight: 600; }
.num-cell { color: var(--subtle); font-family: 'IBM Plex Mono', monospace; font-size: 11px; }
.sla-tag { font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 3px; display: inline-block; }
.sla-tag.vencido { background: var(--red-light); color: var(--red); }
.sla-tag.alerta  { background: var(--orange-light); color: var(--orange); }
.sla-tag.ok      { background: var(--green-light); color: var(--green); }

/* EMPTY STATE */
.empty { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 70px 40px; text-align: center; flex: 1; }
.empty-ico { font-size: 40px; margin-bottom: 16px; }
.empty h3 { font-size: 16px; margin-bottom: 8px; }
.empty p { font-size: 12px; color: var(--muted); line-height: 1.8; }
.empty .hint-tags { display: flex; gap: 6px; justify-content: center; margin-top: 14px; flex-wrap: wrap; }
.hint-tag { background: var(--accent-light); color: var(--accent); border-radius: 4px; padding: 4px 10px; font-size: 11px; font-family: 'IBM Plex Mono', monospace; font-weight: 600; }

/* PROGRESS */
.progress-wrap { padding: 12px 16px; background: var(--orange-light); border-bottom: 1px solid #ffe0a0; display: none; align-items: center; gap: 10px; }
.progress-wrap.show { display: flex; }
.progress-bar-bg { flex: 1; height: 6px; background: #ffe0a0; border-radius: 3px; overflow: hidden; }
.progress-bar { height: 100%; background: var(--orange); border-radius: 3px; transition: width 0.2s; }
.progress-txt { font-size: 11px; color: var(--orange); font-weight: 600; white-space: nowrap; }

/* TOAST */
.toast {
  position: fixed; bottom: 24px; right: 24px; border-radius: 6px;
  padding: 12px 20px; font-size: 13px; font-weight: 500;
  transform: translateY(80px); opacity: 0; transition: all 0.25s; z-index: 9999;
  max-width: 360px; box-shadow: 0 4px 16px rgba(0,0,0,0.2);
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.ok  { background: var(--green-btn); color: #fff; }
.toast.err { background: var(--red); color: #fff; }
.toast.inf { background: var(--text); color: #fff; }

/* SITES FORA */
.sf-layout { display: flex; gap: 16px; flex: 1; min-height: 0; }
.sf-left { width: 360px; flex-shrink: 0; display: flex; flex-direction: column; gap: 12px; }
.sf-right { flex: 1; display: flex; flex-direction: column; gap: 12px; min-width: 0; }

.sf-paste-card {
  background: var(--white); border: 1px solid var(--border); border-radius: 8px;
  padding: 14px; display: flex; flex-direction: column; gap: 10px;
}
.sf-paste-card textarea {
  width: 100%; height: 160px; border: 2px dashed var(--border2); border-radius: 6px;
  padding: 10px; font-family: 'IBM Plex Mono', monospace; font-size: 11px;
  color: var(--text); resize: vertical; outline: none; transition: border-color 0.2s;
  background: var(--bg);
}
.sf-paste-card textarea:focus { border-color: var(--accent); background: var(--white); }
.sf-paste-card textarea::placeholder { color: var(--subtle); }

.sf-col-picker { display: flex; flex-direction: column; gap: 6px; }
.sf-col-label { font-size: 10px; font-weight: 700; color: var(--subtle); text-transform: uppercase; letter-spacing: 0.5px; }
.sf-col-chips { display: flex; flex-wrap: wrap; gap: 4px; }
.sf-col-chip {
  padding: 3px 10px; border-radius: 20px; font-size: 10px; font-weight: 600;
  border: 1px solid var(--border2); background: var(--bg); color: var(--muted);
  cursor: pointer; transition: all 0.15s; font-family: 'IBM Plex Mono', monospace;
}
.sf-col-chip:hover { border-color: var(--red); color: var(--red); background: var(--red-light); }
.sf-col-chip.on { background: var(--red); border-color: var(--red); color: #fff; }

.sf-xlsx-col-picker { display: flex; flex-direction: column; gap: 6px; }
.sf-xlsx-select {
  width: 100%; padding: 7px 10px; border: 1px solid var(--border2); border-radius: 5px;
  font-family: 'IBM Plex Sans', sans-serif; font-size: 12px; color: var(--text);
  background: var(--white); outline: none; cursor: pointer;
}
.sf-xlsx-select:focus { border-color: var(--accent); }

.sf-stats { display: flex; gap: 10px; flex-wrap: wrap; }
.sf-stat {
  background: var(--white); border: 1px solid var(--border); border-radius: 8px;
  padding: 10px 16px; min-width: 100px; flex: 1;
}
.sf-stat-val { font-size: 22px; font-weight: 700; font-family: 'IBM Plex Mono', monospace; line-height: 1; }
.sf-stat-lbl { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 4px; }
.sf-stat.fora .sf-stat-val { color: var(--red); }
.sf-stat.dentro .sf-stat-val { color: var(--green-btn); }
.sf-stat.total .sf-stat-val { color: var(--muted); }

tr.site-fora td { background: #fff0ed !important; }
tr.site-fora:hover td { background: #ffe4de !important; }
.site-fora-tag { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 3px; display: inline-block; background: var(--red-light); color: var(--red); }
.site-dentro-tag { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 3px; display: inline-block; background: var(--green-light); color: var(--green); }
.site-ok-tag { font-size: 10px; color: var(--subtle); padding: 2px 4px; }

.sf-preview-table { font-size: 11px; }
.sf-preview-table th { font-size: 9px; }
.sf-copy-btn {
  background: none; border: 1px solid var(--border2); border-radius: 4px;
  color: var(--muted); cursor: pointer; font-size: 12px; padding: 2px 7px;
  transition: all 0.15s; line-height: 1; font-family: monospace;
}
.sf-copy-btn:hover { background: var(--accent-light); border-color: var(--accent); color: var(--accent); }

/* CHARTS */
.charts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 16px; }
.chart-card { background: var(--white); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }
.chart-title { font-size: 12px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 14px; }
.chart-wrap { position: relative; height: 220px; }

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }
/* OBS DROPDOWN */
.obs-btn {
  padding: 2px 8px; border-radius: 4px; border: 1px solid var(--border2);
  background: var(--bg); color: var(--muted); font-size: 10px; font-weight: 600;
  cursor: pointer; font-family: 'IBM Plex Sans', sans-serif; transition: all 0.15s;
  white-space: nowrap;
}
.obs-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
.obs-btn.has-obs { border-color: var(--green-btn); color: var(--green-btn); background: var(--green-light); }
.obs-btn.obs-normalizado { border-color: var(--green); color: var(--green); background: #b7f5d4; font-weight: 700; }

.obs-dropdown {
  position: fixed; z-index: 9000;
  background: #fff; border: 1px solid var(--border2); border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.15); padding: 6px; min-width: 200px;
  display: none;
}
.obs-dropdown.open { display: block; }
.obs-option {
  padding: 7px 12px; border-radius: 5px; cursor: pointer; font-size: 12px;
  font-weight: 500; transition: background 0.12s; white-space: nowrap;
}
.obs-option:hover { background: var(--accent-light); color: var(--accent); }
.obs-option.selected { background: var(--accent-light); color: var(--accent); font-weight: 700; }
.obs-option.opt-normalizado { color: var(--green); }
.obs-option.opt-normalizado:hover { background: var(--green-light); }
.obs-option.opt-normalizado.selected { background: #b7f5d4; color: var(--green); }
.obs-option.opt-limpar { color: var(--subtle); font-style: italic; }
.obs-option.opt-limpar:hover { background: var(--red-light); color: var(--red); }

tr.row-normalizado td { background: #d4f8e8 !important; }
tr.row-normalizado:hover td { background: #b7f5d4 !important; }

</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-logo">
    <div class="dot"></div>
    CSM FIXA · Extrator de Fila
  </div>
  <div class="topbar-right">
    <div class="tab-nav">
      <button class="tab-btn active" onclick="switchTab('tabela')">📋 Tabela</button>
      <button class="tab-btn" onclick="switchTab('graficos')">📊 Gráficos</button>
      <button class="tab-btn" id="tabSitesFora" onclick="switchTab('sitesfora')">🔴 Sites Fora</button>
    </div>
    <span class="topbar-hint">BAIXADA · OESTE · GRANDE RJ · INTERIOR · ES</span>
  </div>
</div>

<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">

    <div>
      <div class="sec-label">📂 Arquivos por área</div>
