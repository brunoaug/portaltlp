// ─── Aplicar & Renderizar ──────────────────────────────────────
function applyAndRender() {
  filteredRows = [];
  ALL_AREAS.forEach(area => {
    if (!areaData[area]) return;
    areaData[area].rows.forEach(row => {
      // Comparação normalizada — resolve diferenças de case/espaço
      const fila   = normFila(row[REGRA_COL]  || '');
      const estado = String(row[ESTADO_COL] || '').trim();
      const prio   = String(row[PRIO_COL]   || '').trim();

      if (selectedNorms.size && !selectedNorms.has(fila)) return;
      if (selectedEstados.size && !selectedEstados.has(estado)) return;
      if (selectedPrios.size   && !selectedPrios.has(prio))     return;

      filteredRows.push({ ...row, __area: area });
    });
  });

  if (sortCol) {
    filteredRows.sort((a, b) => {
      const av = String(a[sortCol] ?? ''), bv = String(b[sortCol] ?? '');
      return av.localeCompare(bv, 'pt-BR', { numeric: true }) * sortDir;
    });
  }

  renderTable();
  updateStats();
  document.getElementById('btnExport').disabled  = !filteredRows.length;
  document.getElementById('btnInverse').disabled = !getInverseRows().length;
}

function getInverseRows() {
  const rows = [];
  ALL_AREAS.forEach(area => {
    if (!areaData[area]) return;
    areaData[area].rows.forEach(row => {
      const fila   = normFila(row[REGRA_COL]  || '');
      const estado = String(row[ESTADO_COL] || '').trim();
      const prio   = String(row[PRIO_COL]   || '').trim();
      if (!selectedNorms.size || selectedNorms.has(fila)) return;
      if (selectedEstados.size && !selectedEstados.has(estado)) return;
      if (selectedPrios.size   && !selectedPrios.has(prio))     return;
      rows.push({ ...row, __area: area });
    });
  });
  return rows;
}

// ─── SLA ───────────────────────────────────────────────────────
function parseSLA(val) {
  if (!val) return null;
  if (val instanceof Date) return val;
  const s = String(val);
  const m = s.match(/(\d{2})\/(\d{2})\/(\d{4})(?:\s+(\d{2}):(\d{2}))?/);
  if (m) return new Date(+m[3], +m[2]-1, +m[1], +(m[4]||0), +(m[5]||0));
  const d = new Date(s);
  return isNaN(d) ? null : d;
}
function slaStatus(row) {
  for (const col of SLA_COLS) {
    if (row[col] === undefined) continue;
    const d = parseSLA(row[col]);
    if (!d) continue;
    const diff = (d - new Date()) / 3600000;
    if (diff < 0) return 'vencido';
    if (diff < 4) return 'alerta';
    return 'ok';
  }
  return null;
}

// ─── Tabela ────────────────────────────────────────────────────
function rowSiteFora(row) {
  if (!sfSiteIds.size) return false;
  const xlsxCol = document.getElementById('sfXlsxCol')?.value;
  if (!xlsxCol) return false;
  const cellVal = normId(row[xlsxCol] ?? '');
  if (!cellVal) return false;
  for (const id of sfSiteIds) {
    if (cellVal === id || cellVal.includes(id) || id.includes(cellVal)) return true;
  }
  return false;
}

