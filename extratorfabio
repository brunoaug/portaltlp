        ${cols.map(c => `<th ${c===REGRA_COL?'class="key-col"':''} onclick="setSort(${JSON.stringify(c)})">${esc(c)} <span class="sort-arrow">${sortArrow(c)}</span></th>`).join('')}
      </tr></thead>
      <tbody>
        ${aRows.map((row, i) => {
          const sl   = slaStatus(row);
          const sf   = rowSiteFora(row);
          const tsk  = String(row['TSK'] ?? '').trim();
          const obs  = obsMap[tsk] || '';
          const isNorm = obs === 'Normalizado';
          let cls = isNorm ? 'row-normalizado' : (sf ? 'site-fora' : (sl === 'vencido' ? 'sla-vencido' : sl === 'alerta' ? 'sla-alerta' : ''));
          const obsBtnCls = isNorm ? 'obs-btn obs-normalizado' : (obs ? 'obs-btn has-obs' : 'obs-btn');
          const obsBtnLbl = obs ? obs : '+ OBS';
          return `<tr class="${cls}">
            <td class="num-cell">${i+1}</td>
            <td><span class="area-cell ${area}">${AREA_LABELS[area]}</span></td>
            <td>${sf ? '<span class="site-fora-tag">🔴 FORA</span>' : '<span class="site-ok-tag">✅</span>'}</td>
            <td><button type="button" class="${obsBtnCls} obs-open-btn" data-tsk="${esc(tsk)}" title="${esc(obs)}">${esc(obsBtnLbl)}</button></td>
            ${cols.map(c => {
              const v = String(row[c] ?? '');
              if (c === REGRA_COL) return `<td><span class="regra-cell" title="${esc(v)}">${esc(v)}</span></td>`;
              if (SLA_COLS.includes(c) && sl) return `<td><span class="sla-tag ${sl}">${esc(v)}</span></td>`;
              const d = v.length > 50 ? v.slice(0,48)+'…' : v;
              return `<td title="${esc(v)}">${esc(d)}</td>`;
            }).join('')}
