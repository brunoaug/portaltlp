    charts[id] = new Chart(document.getElementById(id), {
      type: 'bar',
      data: { labels: sorted.map(([k])=>k.length>28?k.slice(0,26)+'…':k), datasets: [{ label, data: sorted.map(([,v])=>v), backgroundColor: palette, borderRadius: 4 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { font: { size: 10 }, maxRotation: 35 } }, y: { ticks: { font: { size: 10 } }, beginAtZero: true } } }
    });
  };
  const makeDoughnut = (id, data, label) => {
    const sorted = Object.entries(data).sort((a,b)=>b[1]-a[1]);
    if (charts[id]) charts[id].destroy();
    charts[id] = new Chart(document.getElementById(id), {
      type: 'doughnut',
      data: { labels: sorted.map(([k])=>k), datasets: [{ label, data: sorted.map(([,v])=>v), backgroundColor: palette, borderWidth: 2 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { font: { size: 10 }, boxWidth: 12 } } } }
    });
  };

  makeBar('chartFila', countBy(REGRA_COL), 'OS');
  makeDoughnut('chartArea', (() => { const m={}; filteredRows.forEach(r=>{const a=AREA_LABELS[r.__area];m[a]=(m[a]||0)+1;}); return m; })(), 'OS');
  makeDoughnut('chartEstado',     countBy(ESTADO_COL), 'OS');
  makeDoughnut('chartPrioridade', countBy(PRIO_COL),   'OS');
}

// ─── Stats ─────────────────────────────────────────────────────
function updateStats() {
  const total  = ALL_AREAS.reduce((s,a) => s + (areaData[a]?.rows.length||0), 0);
  const loaded = ALL_AREAS.filter(a => areaData[a]).length;
  let rows = filteredRows;
  if (searchQuery) rows = rows.filter(r => Object.values(r).some(v => String(v).toLowerCase().includes(searchQuery)));
  let slaV = 0;
  rows.forEach(r => { if (slaStatus(r) === 'vencido') slaV++; });
  document.getElementById('sTot').textContent        = total;
  document.getElementById('sFilt').textContent       = rows.length;
  document.getElementById('sAreas').textContent      = loaded;
  document.getElementById('sFilas').textContent      = selectedNorms.size;
  document.getElementById('sSlaVencido').textContent = slaV;
}

// ─── Helpers ───────────────────────────────────────────────────
function showProgress(show, txt='', pct=0) {
  const wrap = document.getElementById('progressWrap');
  wrap.classList.toggle('show', show);
  if (show) { document.getElementById('progressTxt').textContent=txt; document.getElementById('progressBar').style.width=pct+'%'; }
}
function esc(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function toast(msg, type='inf') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast ${type} show`;
  clearTimeout(t._t); t._t = setTimeout(()=>t.classList.remove('show'), 4000);
}


// ─── Debug ─────────────────────────────────────────────────────
function runDebug() {
  const panel = document.getElementById('debugPanel');
  panel.style.display = 'block';
  let out = '';
  out += '=== selectedNorms (' + selectedNorms.size + ') ===\n';
  for (const n of selectedNorms) out += '  "' + n + '"\n';
  out += '\n=== userDeselNorms (' + userDeselNorms.size + ') ===\n';
  for (const n of userDeselNorms) out += '  "' + n + '"\n';
  out += '\n=== allFilas ===\n';
  for (const [orig, info] of allFilas) {
    const match = selectedNorms.has(info.norm);
    out += '  orig: "' + orig + '"\n';
    out += '  norm: "' + info.norm + '" | total: ' + info.total + ' | selected: ' + match + '\n\n';
  }
  out += '=== filteredRows: ' + filteredRows.length + ' ===\n';
  out += '=== areaData loaded: ' + ALL_AREAS.filter(a=>areaData[a]).join(', ') + '\n';
  // Sample first 3 rows normFila check
  out += '\n=== Sample rows normFila check ===\n';
  let count = 0;
  ALL_AREAS.forEach(area => {
    if (!areaData[area] || count > 5) return;
    areaData[area].rows.slice(0, 3).forEach(row => {
      if (count > 5) return;
      const fila = normFila(row[REGRA_COL] || '');
      const match = !selectedNorms.size || selectedNorms.has(fila);
      out += '  raw: "' + String(row[REGRA_COL]||'') + '"\n';
      out += '  norm: "' + fila + '" | inSelected: ' + selectedNorms.has(fila) + ' | passes: ' + match + '\n\n';
      count++;
    });
  });
  panel.textContent = out;
}

// ─── Sites Fora ────────────────────────────────────────────────
function parsePaste() {
  const raw = document.getElementById('sfPasteArea').value.trim();
  if (!raw) {
    sfParsedRows=[]; sfHeaders=[]; sfSelectedCol=null; sfSiteIds.clear();
    document.getElementById('sfColPicker').style.display = 'none';
    document.getElementById('sfXlsxConfig').style.display = 'none';
    document.getElementById('sfStats').style.display = 'none';
    renderSfTable([]);
    renderTable(); // atualiza coluna SITE na tabela principal
    return;
  }
  const lines = raw.split(/\r?\n/).filter(l => l.trim());
  const firstLine = lines[0];
  let sep = '\t';
  if ((firstLine.match(/\t/g)||[]).length >= 1)    sep = '\t';
  else if ((firstLine.match(/;/g)||[]).length >= 1)  sep = ';';
  else if ((firstLine.match(/,/g)||[]).length >= 1)  sep = ',';
  else sep = /\s{2,}/.test(firstLine) ? 'spaces' : '\t';

  const splitLine = l => sep === 'spaces' ? l.trim().split(/\s{2,}/) : l.split(sep).map(c=>c.trim());
  const headerLine = splitLine(lines[0]);
  const dataLines  = lines.slice(1);

  let headers, rows;
  if (headerLine.length === 1) {
    headers = ['ID'];
    rows = lines.map(l => ({ ID: l.trim() }));
  } else {
    headers = headerLine;
    rows = dataLines.map(l => {
      const cols = splitLine(l);
      const obj = {};
      headers.forEach((h, i) => { obj[h] = cols[i] ?? ''; });
      return obj;
    }).filter(r => Object.values(r).some(v => v.trim()));
  }

  sfParsedRows = rows; sfHeaders = headers;

  const scores = headers.map(h => {
    const vals = rows.map(r => normId(r[h])).filter(Boolean);
    const hits  = vals.filter(v => SITE_ID_REGEX.test(v)).length;
    return { h, score: vals.length ? hits/vals.length : 0 };
  });
  const best = scores.sort((a,b)=>b.score-a.score)[0];
  sfSelectedCol = best && best.score > 0 ? best.h : headers[0];

  renderColPicker();
  updateSiteIds();
  buildXlsxColSelect();
  document.getElementById('sfColPicker').style.display = 'flex';
  document.getElementById('sfXlsxConfig').style.display = 'flex';
  runComparison();
}

function renderColPicker() {
  const el = document.getElementById('sfColChips');
  el.innerHTML = sfHeaders.map(h => {
    const on = h === sfSelectedCol;
    const sample = sfParsedRows.slice(0,3).map(r=>normId(r[h])).filter(Boolean).join(', ');
    return `<span class="sf-col-chip ${on?'on':''}" data-col="${esc(h)}" onclick="selectSfCol(this)" title="${esc(sample)}">${esc(h)}</span>`;
  }).join('');
}

function selectSfCol(el) {
  sfSelectedCol = el.dataset.col;
  document.querySelectorAll('.sf-col-chip').forEach(c => c.classList.remove('on'));
  el.classList.add('on');
  updateSiteIds();
  runComparison();
}

function updateSiteIds() {
  sfSiteIds.clear();
  if (!sfSelectedCol) return;
  sfParsedRows.forEach(r => { const v = normId(r[sfSelectedCol]); if (v) sfSiteIds.add(v); });
}

function buildXlsxColSelect() {
  const sel = document.getElementById('sfXlsxCol');
  const cols = new Set();
  ALL_AREAS.forEach(area => {
    if (!areaData[area]?.rows?.length) return;
    Object.keys(areaData[area].rows[0]).forEach(c => { if (c !== '__area') cols.add(c); });
  });
  if (!cols.size) { sel.innerHTML = '<option value="">— carregue um arquivo Excel primeiro —</option>'; return; }
  const colList = [...cols];
  const neIdCol = colList.find(c => /^NE[\s_-]?ID$/i.test(c.trim()));
  const prio    = colList.filter(c => /\b(NE|END|NODE|SITE|ID)\b/i.test(c) && c !== neIdCol);
  const sorted  = [...(neIdCol?[neIdCol]:[]), ...prio, ...colList.filter(c=>c!==neIdCol&&!prio.includes(c))];
  const prev = sel.value;
  sel.innerHTML = sorted.map(c=>`<option value="${esc(c)}" ${c===prev?'selected':''}>${esc(c)}</option>`).join('');
  if (neIdCol && (!prev || !cols.has(prev))) sel.value = neIdCol;
  else if (!prev && sorted.length) sel.value = sorted[0];
}

function runComparison() {
  const xlsxCol = document.getElementById('sfXlsxCol').value;
  if (!sfSiteIds.size || !xlsxCol) return;

  sfResults = [];
  ALL_AREAS.forEach(area => {
    if (!areaData[area]) return;
    areaData[area].rows.forEach(row => {
      const cellVal = normId(row[xlsxCol] ?? '');
      if (!cellVal) return;
      let found = false;
      for (const id of sfSiteIds) {
        if (cellVal === id || cellVal.includes(id) || id.includes(cellVal)) { found=true; break; }
      }
      if (found) sfResults.push({ ...row, __area: area, __siteStatus: 'fora' });
    });
  });

  const sfFora = sfResults.length;
  document.getElementById('sfStats').style.display  = 'flex';
  document.getElementById('sfTotal').textContent    = sfSiteIds.size;
  document.getElementById('sfFora').textContent     = sfFora;
  document.getElementById('sfDentro').textContent   = Math.max(0, sfSiteIds.size - sfFora);
  document.getElementById('sfBtnExport').disabled   = !sfResults.length;

  renderSfTable(sfResults);
  renderTable(); // atualiza coluna SITE na tabela principal
}

function renderSfTable(rows) {
  const container = document.getElementById('sfTableContainer');
  const badge     = document.getElementById('sfResultBadge');
  badge.textContent = rows.length ? `${rows.length} OS` : '—';

  if (!rows.length) {
    container.innerHTML = `<div class="empty"><div class="empty-ico">📡</div><h3>Nenhuma OS encontrada</h3><p>Nenhuma OS tem site correspondente nos dados colados.</p></div>`;
    return;
  }

  const xlsxCol = document.getElementById('sfXlsxCol').value;
  const allLines = rows.map(r => {
    const tsk   = String(r['TSK']??'').trim()||'—';
    const neId  = String(r[xlsxCol]??'').trim()||'—';
    const prio  = String(r['Prioridade']??'').trim()||'—';
    const est   = String(r['Estado']??'').trim()||'—';
    return `${tsk} / ${neId} - ${prio} - ${est}`;
  }).join('\n');

  const byArea = {};
  rows.forEach(r => { if (!byArea[r.__area]) byArea[r.__area]=[]; byArea[r.__area].push(r); });

  let html = `<div style="padding:10px 16px;border-bottom:1px solid var(--border);background:#fafbfc;display:flex;align-items:center;gap:10px;">
    <span style="font-size:11px;font-weight:700;color:var(--muted)">📋 CÓPIA RÁPIDA</span>
    <button onclick="copySfAll()" style="padding:5px 14px;border-radius:4px;border:1px solid var(--accent);background:var(--accent-light);color:var(--accent);font-size:11px;font-weight:700;cursor:pointer;">⎘ Copiar todas (${rows.length})</button>
    <span style="font-size:10px;color:var(--subtle);font-family:'IBM Plex Mono',monospace">TSK / NE-ID - PRIORIDADE - STATUS</span>
  </div>`;

  ALL_AREAS.forEach(area => {
    if (!byArea[area]) return;
    const aRows   = byArea[area];
    const allKeys = Object.keys(aRows[0]).filter(c=>c!=='__area'&&c!=='__siteStatus');
    let cols = DISPLAY_COLS.filter(c=>allKeys.includes(c));
    if (!cols.length) cols = allKeys.slice(0,10);
    const priorityCols = ['TSK', xlsxCol].filter(c=>allKeys.includes(c)&&!cols.includes(c));
    cols = [...priorityCols, ...cols];

    html += `<table class="sf-preview-table">
      <thead><tr><th>#</th><th>ÁREA</th><th>STATUS</th><th>⎘</th>
        ${cols.map(c=>`<th style="${c==='TSK'||c===xlsxCol?'color:var(--accent);background:var(--accent-light)':''}">${esc(c)}</th>`).join('')}
      </tr></thead>
      <tbody>
        ${aRows.map((row,i)=>{
          const tsk=String(row['TSK']??'').trim()||'—', neId=String(row[xlsxCol]??'').trim()||'—';
          const prio=String(row['Prioridade']??'').trim()||'—', est=String(row['Estado']??'').trim()||'—';
          const copyTxt=`${tsk} / ${neId} - ${prio} - ${est}`;
          return `<tr class="site-fora">
            <td class="num-cell">${i+1}</td>
            <td><span class="area-cell ${area}">${AREA_LABELS[area]}</span></td>
            <td><span class="site-fora-tag">🔴 SITE FORA</span></td>
            <td><button class="sf-copy-btn" onclick="copySfRow(this)" data-txt="${esc(copyTxt)}">⎘</button></td>
            ${cols.map(c=>{
              const v=String(row[c]??'');
              if(c===REGRA_COL) return `<td><span class="regra-cell" title="${esc(v)}">${esc(v)}</span></td>`;
              const d=v.length>40?v.slice(0,38)+'…':v;
              return `<td title="${esc(v)}" style="${c==='TSK'||c===xlsxCol?'font-weight:700;color:var(--accent);font-family:\'IBM Plex Mono\',monospace':''}">${esc(d)}</td>`;
            }).join('')}
          </tr>`;
        }).join('')}
      </tbody></table>`;
  });

  container._allLines = allLines;
  container.innerHTML = html;
}

function copySfRow(btn) {
  navigator.clipboard.writeText(btn.dataset.txt).then(() => {
    btn.textContent='✓'; btn.style.color='var(--green-btn)';
    setTimeout(()=>{btn.textContent='⎘';btn.style.color='';},1500);
    toast(`📋 Copiado!`, 'ok');
  }).catch(()=>toast('❌ Erro ao copiar','err'));
}
function copySfAll() {
  const txt = document.getElementById('sfTableContainer')._allLines||'';
  if (!txt) return;
  navigator.clipboard.writeText(txt).then(()=>toast(`📋 ${sfResults.length} linhas copiadas!`,'ok')).catch(()=>toast('❌ Erro ao copiar','err'));
}

function exportSitesFora() {
  if (!sfResults.length) { toast('❌ Sem dados para exportar','err'); return; }
  const wb = XLSX.utils.book_new();
  const byArea = {};
  sfResults.forEach(({__area,__siteStatus,...row})=>{
    if(!byArea[__area]) byArea[__area]=[];
    byArea[__area].push({'STATUS SITE':'🔴 SITE FORA',...row});
  });
  ALL_AREAS.forEach(area => {
    if (!byArea[area]?.length) return;
    const ws = XLSX.utils.json_to_sheet(byArea[area]);
    const range = XLSX.utils.decode_range(ws['!ref']||'A1');
    for (let C=range.s.c;C<=range.e.c;C++) {
      const addr=XLSX.utils.encode_cell({r:0,c:C});
      if(ws[addr]) ws[addr].s={font:{bold:true,color:{rgb:'FFFFFF'},sz:11},fill:{fgColor:{rgb:'BF2600'}},alignment:{horizontal:'center'}};
    }
    const colWidths=[];
    for(let C=range.s.c;C<=range.e.c;C++){
      let maxW=10;
      for(let R=range.s.r;R<=Math.min(range.e.r,50);R++){const cell=ws[XLSX.utils.encode_cell({r:R,c:C})];if(cell?.v!=null)maxW=Math.max(maxW,String(cell.v).length);}
      colWidths.push({wch:Math.min(maxW+2,50)});
    }
    ws['!cols']=colWidths;
    XLSX.utils.book_append_sheet(wb,ws,SHEET_NAMES[area]);
  });
  const date=new Date().toLocaleDateString('pt-BR').replace(/\//g,'-');
  const fname=`REPORT_CSM_FIXA_SITES_FORA_${date}.xlsx`;
  XLSX.writeFile(wb,fname);
  toast(`⬇ ${sfResults.length} OS exportadas → ${fname}`,'ok');
}
