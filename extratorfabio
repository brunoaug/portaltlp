<script>
// ─── Configuração ──────────────────────────────────────────────
const REGRA_COL  = 'Regra usuário criador';
const ESTADO_COL = 'Estado';
const PRIO_COL   = 'Prioridade';
const SLA_COLS   = ['Fim SLA', 'ETA'];

const AREA_LABELS   = { B: 'BAIXADA', O: 'OESTE', G: 'GRANDE RJ', I: 'INTERIOR', E: 'ESPÍRITO SANTO' };
const ALL_AREAS     = ['B','O','G','I','E'];
const EXPORT_COLORS = { B: '0052CC', O: '006644', G: '6554C0', I: 'B85C00', E: '006B75' };
const SHEET_NAMES   = { B: 'BAIXADA', O: 'OESTE', G: 'GRANDE RJ', I: 'INTERIOR', E: 'ESPIRITO SANTO' };

const DISPLAY_COLS = [
  'FILA EM QUE ESTÁ','TSK','Estado','Fim SLA',
  'Bairro','BSC/RNC','CM','END_ID','NE ID','Título do Alarme','P',
];
const TSK_SOURCE_COL = 'Número de Ordem';

// ─── Estado ────────────────────────────────────────────────────
const areaData      = { B: null, O: null, G: null, I: null, E: null };
let allFilas        = new Map();   // nome_original → { total, norm }
let selectedNorms   = new Set();   // nomes NORMALIZADOS selecionados
let userDeselNorms  = new Set();   // nomes NORMALIZADOS explicitamente desmarcados
let selectedEstados = new Set();
let selectedPrios   = new Set();
let filteredRows    = [];
let searchQuery     = '';
let sortCol         = null;
let sortDir         = 1;
let charts          = {};

// ─── OBS Map ───────────────────────────────────────────────────
// Chave: TSK da OS. Valor: string da opção escolhida ou ''
const obsMap = {};

const OBS_OPTIONS = [
  'Falta de Sobressalente',
  'Associação',
  'Sem Acesso',
  'Critica de Encerramento',
  'Em acionamento',
  'Normalizado',
];

let _obsDropdownOpen = null; // TSK atualmente com dropdown aberto

function openObsDropdown(tsk, btn) {
  try {
    closeObsDropdown();
    const menu = document.getElementById('obsDropdownMenu');
    const current = obsMap[tsk] || '';
    let html = '';
    for (const opt of OBS_OPTIONS) {
      const selected = current === opt ? ' selected' : '';
      const extra = opt === 'Normalizado' ? ' opt-normalizado' : '';
      html += '<div class="obs-option'+extra+selected+'" data-tsk="'+tsk+'" data-val="'+opt+'">'+opt+'</div>';
    }
    if (current) {
      html += '<div class="obs-option opt-limpar" data-tsk="'+tsk+'" data-val="">✕ Limpar</div>';
    }
    menu.innerHTML = html;
    menu.querySelectorAll('.obs-option').forEach(el=>{
      el.onclick = function(ev){
        ev.stopPropagation();
        selectObs(this.dataset.tsk, this.dataset.val);
      };
    });
    const rect = btn.getBoundingClientRect();
    menu.style.top = (rect.bottom + window.scrollY + 4) + 'px';
    menu.style.left = (rect.left + window.scrollX) + 'px';
    menu.style.display = 'block';
    menu.classList.add('open');
    _obsDropdownOpen = tsk;
  } catch(err) { console.error(err); }
}

function closeObsDropdown() {
  const m = document.getElementById('obsDropdownMenu');
  if (!m) return;
  m.classList.remove('open');
  m.style.display='none';
  _obsDropdownOpen = null;
}

function selectObs(tsk, value) {
  if (value === '') { delete obsMap[tsk]; }
  else              { obsMap[tsk] = value; }
  closeObsDropdown();
  renderTable(); // re-renderiza para atualizar botão e cor da linha
}


document.addEventListener('click', function(e){
  const btn = e.target.closest('.obs-open-btn');
  if (btn){
    e.stopPropagation();
    openObsDropdown(btn.dataset.tsk, btn);
  }
});

// Fecha dropdown ao clicar fora
document.addEventListener('click', function(e) {
  if (!e.target.classList.contains('obs-btn') &&
      !document.getElementById('obsDropdownMenu').contains(e.target)) {
    closeObsDropdown();
  }
}, true);

// Sites Fora
let sfParsedRows  = [];
let sfHeaders     = [];
let sfSelectedCol = null;
let sfSiteIds     = new Set();   // IDs normalizados do paste
let sfResults     = [];

const SITE_ID_REGEX = /^[A-Z]{2,}[-]?[A-Z0-9]{2,}[0-9]+$/i;

// ─── Normalização ──────────────────────────────────────────────
// CHAVE: toda comparação de fila usa normFila() dos dois lados
function normFila(v) {
  return String(v).trim().toUpperCase().replace(/\s+/g, ' ');
}
function normId(v) {
  return String(v).trim().toUpperCase().replace(/\s+/g, '');
}

// ─── Tabs ──────────────────────────────────────────────────────
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  const panel = document.getElementById('panel-' + tab);
  if (panel) panel.classList.add('active');
  const btn = document.querySelector('.tab-btn[onclick="switchTab(\'' + tab + '\')"]');
  if (btn) btn.classList.add('active');
  if (tab === 'graficos') renderCharts();
  if (tab === 'sitesfora') buildXlsxColSelect();
}

// ─── Drag & Drop ───────────────────────────────────────────────
function handleDragOver(e, area) {
  if (areaData[area]) return;
  e.preventDefault();
  document.getElementById('slot-' + area).classList.add('drag-over');
}
function handleDragLeave(e, area) {
  document.getElementById('slot-' + area).classList.remove('drag-over');
}
function handleDrop(e, area) {
  e.preventDefault();
  document.getElementById('slot-' + area).classList.remove('drag-over');
  if (areaData[area]) return;
  const file = e.dataTransfer.files[0];
  if (file) processFile(file, area);
}

// ─── Upload ────────────────────────────────────────────────────
function triggerUpload(area) {
  if (areaData[area]) return;
  document.getElementById('fi-' + area).click();
}
function handleFile(ev, area) {
  const file = ev.target.files[0];
  if (!file) return;
  ev.target.value = '';
  processFile(file, area);
}

function normalizeRow(row) {
  const out = { ...row };
  if (!out['TSK'] || String(out['TSK']).trim() === '') {
    const src = String(out[TSK_SOURCE_COL] || '').trim();
    out['TSK'] = src ? (src.toUpperCase().startsWith('TSK') ? src : 'TSK' + src) : '';
  }
  if (!out['FILA EM QUE ESTÁ']) out['FILA EM QUE ESTÁ'] = out[REGRA_COL] || '';
  if (!out['P'] || String(out['P']).trim() === '') {
    const p = String(out[PRIO_COL] || '').trim();
    const m = p.match(/P\d/i);
    out['P'] = m ? m[0].toUpperCase() : p;
  }
  return out;
}

function processFile(file, area) {
  showProgress(true, 'Lendo arquivo…', 20);
  const reader = new FileReader();
  reader.onload = e => {
    try {
      showProgress(true, 'Processando planilha…', 55);
      const wb = XLSX.read(e.target.result, { type: 'binary', cellDates: true });
      let rows = null, foundSheet = null;
      for (const sn of wb.SheetNames) {
        const c = XLSX.utils.sheet_to_json(wb.Sheets[sn], { defval: '' });
        if (c.length && c[0].hasOwnProperty(REGRA_COL)) { rows = c; foundSheet = sn; break; }
      }
      if (!rows) {
        foundSheet = wb.SheetNames[0];
        rows = XLSX.utils.sheet_to_json(wb.Sheets[foundSheet], { defval: '' });
      }
      rows = rows.map(normalizeRow);
      areaData[area] = { rows, fileName: file.name, sheetName: foundSheet };

      const slot = document.getElementById('slot-' + area);
      slot.className = `slot loaded ${area}`;
      slot.onclick = null;
      document.getElementById('sub-' + area).textContent = `${file.name}  ·  ${rows.length} linhas`;
      if (!slot.querySelector('.slot-x')) {
        const btn = document.createElement('button');
        btn.className = 'slot-x'; btn.innerHTML = '✕'; btn.title = 'Remover arquivo';
        btn.onclick = ev => { ev.stopPropagation(); removeArea(area); };
        slot.appendChild(btn);
      }
      showProgress(true, 'Construindo filtros…', 85);
      userDeselNorms.clear(); // reset ao carregar novo arquivo
      rebuildFilas();
      showProgress(false);
      toast(`✅ ${AREA_LABELS[area]}: ${rows.length} linhas (aba "${foundSheet}")`, 'ok');
    } catch(err) {
      showProgress(false);
      toast(`❌ Erro ao ler arquivo da área ${AREA_LABELS[area]}: ${err.message}`, 'err');
    }
  };
  reader.readAsBinaryString(file);
}

function removeArea(area) {
  areaData[area] = null;
  const slot = document.getElementById('slot-' + area);
  slot.className = 'slot';
  slot.onclick = () => triggerUpload(area);
  slot.ondragover  = e => handleDragOver(e, area);
  slot.ondragleave = e => handleDragLeave(e, area);
  slot.ondrop      = e => handleDrop(e, area);
  document.getElementById('sub-' + area).textContent = 'Clique ou arraste o arquivo';
  const x = slot.querySelector('.slot-x');
  if (x) x.remove();
  rebuildFilas();
  toast(`🗑️ ${AREA_LABELS[area]} removida`, 'inf');
}

// ─── Filas ─────────────────────────────────────────────────────
function rebuildFilas() {
  allFilas = new Map();  // chave = nome original, valor = { norm, total }
  ALL_AREAS.forEach(area => {
    if (!areaData[area]) return;
    areaData[area].rows.forEach(row => {
      const orig = String(row[REGRA_COL] || '').trim();
      if (!orig) return;
      const norm = normFila(orig);
      if (!allFilas.has(orig)) allFilas.set(orig, { norm, total: 0 });
      allFilas.get(orig).total++;
    });
  });

  // Reconstrói selectedNorms:
  // Tudo marcado por padrão. Só fica desmarcado o que o usuário desmarcou explicitamente.
  const existingNorms = new Set([...allFilas.values()].map(v => v.norm));
  const valid = new Set();
  for (const n of existingNorms) {
    if (!userDeselNorms.has(n)) valid.add(n);
  }
  selectedNorms = valid;

  rebuildExtraFilters();
  const anyLoaded = ALL_AREAS.some(a => areaData[a]);
  document.getElementById('statsRow').style.display    = anyLoaded ? 'flex' : 'none';
  document.getElementById('extraFilters').style.display = anyLoaded ? 'flex' : 'none';
  renderFilterList();
  applyAndRender();
  buildXlsxColSelect();
}

function rebuildExtraFilters() {
  const estados = new Set(), prios = new Set();
  ALL_AREAS.forEach(area => {
    if (!areaData[area]) return;
    areaData[area].rows.forEach(row => {
      const e = String(row[ESTADO_COL] || '').trim();
      const p = String(row[PRIO_COL]   || '').trim();
      if (e) estados.add(e);
      if (p) prios.add(p);
    });
  });
  for (const e of selectedEstados) if (!estados.has(e)) selectedEstados.delete(e);
  for (const p of selectedPrios)   if (!prios.has(p))   selectedPrios.delete(p);
  renderChips('chipsEstado',     [...estados].sort(), selectedEstados, 'estado');
  renderChips('chipsPrioridade', [...prios].sort(),   selectedPrios,   'prio');
}

function renderChips(id, values, selected, type) {
  const el = document.getElementById(id);
  if (!values.length) { el.innerHTML = '<span style="font-size:10px;color:var(--subtle)">—</span>'; return; }
  el.innerHTML = values.map(v => {
    const on = selected.has(v);
    return `<span class="chip ${on?'on':''}" data-type="${type}" data-val="${esc(v)}" onclick="toggleChip(this)">${esc(v)}</span>`;
  }).join('');
}

function toggleChip(el) {
  const set = el.dataset.type === 'estado' ? selectedEstados : selectedPrios;
  const val = el.dataset.val;
  if (set.has(val)) { set.delete(val); el.classList.remove('on'); }
  else              { set.add(val);    el.classList.add('on'); }
  applyAndRender();
}

function renderFilterList() {
  const container = document.getElementById('filterList');
  if (!allFilas.size) {
    container.innerHTML = '<div style="color:var(--muted);font-size:11px;line-height:1.6;padding:4px">Carregue um arquivo para ver os filtros disponíveis.</div>';
    return;
  }
  const sorted = [...allFilas.entries()].sort((a, b) => a[0].localeCompare(b[0]));
  container.innerHTML = sorted.map(([nome, info]) => {
    const n  = info.norm;
    const on = selectedNorms.has(n);
    return `
      <label class="filter-item ${on?'on':''}" data-norm="${esc(n)}">
        <input type="checkbox" ${on?'checked':''} onchange="toggleFila(this)">
        <span class="filter-name">${esc(nome)}</span>
        <span class="filter-badge">${info.total}</span>
      </label>`;
  }).join('');
}

function toggleFila(cb) {
  const label = cb.closest('.filter-item');
  const norm  = label.dataset.norm;
  if (cb.checked) { selectedNorms.add(norm); userDeselNorms.delete(norm); label.classList.add('on'); }
  else            { selectedNorms.delete(norm); userDeselNorms.add(norm); label.classList.remove('on'); }
  applyAndRender();
}

function selectAllFilas() {
  for (const [,info] of allFilas) { selectedNorms.add(info.norm); userDeselNorms.delete(info.norm); }
  renderFilterList(); applyAndRender();
}
function clearAllFilas() {
  selectedNorms.clear();
  for (const [,info] of allFilas) userDeselNorms.add(info.norm);
  renderFilterList(); applyAndRender();
}

