// Gera cor de fundo claro a partir do hex escuro (mistura com branco)
function lightenHex(hex, amount) {
  const r = parseInt(hex.slice(0,2),16), g = parseInt(hex.slice(2,4),16), b = parseInt(hex.slice(4,6),16);
  const lr = Math.round(r + (255-r)*amount), lg = Math.round(g + (255-g)*amount), lb = Math.round(b + (255-b)*amount);
  return [lr,lg,lb].map(v=>v.toString(16).padStart(2,'0')).join('').toUpperCase();
}

