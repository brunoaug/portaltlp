  });
  container.innerHTML = html;
}

function sortArrow(col) { return sortCol !== col ? '↕' : sortDir === 1 ? '↑' : '↓'; }
function setSort(col) {
  if (sortCol === col) sortDir *= -1; else { sortCol = col; sortDir = 1; }
  applyAndRender();
}

