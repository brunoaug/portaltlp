function isSiteForaRow(row) {
  const xlsxCol = document.getElementById('sfXlsxCol')?.value;
  if (!sfSiteIds.size || !xlsxCol) return false;
  const cellVal = normId(row[xlsxCol] ?? '');
  if (!cellVal) return false;
  for (const id of sfSiteIds) {
    if (cellVal === id || cellVal.includes(id) || id.includes(cellVal)) return true;
  }
  return false;
}

function parseSLADate(val) {
  // Formatos aceitos:
  // dd/MM/yy HH:mm   → ex: 17/04/26 15:49  (ano 2 dígitos)
  // dd/MM/yyyy HH:mm → ex: 17/04/2026 15:49 (ano 4 dígitos)
  if (!val) return null;
  if (val instanceof Date) return val;
  const s = String(val).trim();

  // Tenta dd/MM/yy(yy) HH:mm(:ss)?
  const m = s.match(/^(\d{2})\/(\d{2})\/(\d{2,4})(?:[T\s](\d{2}):(\d{2})(?::(\d{2}))?)?/);
  if (m) {
    let year = +m[3];
    if (year < 100) year += 2000; // 26 → 2026
    return new Date(year, +m[2]-1, +m[1], +(m[4]||0), +(m[5]||0), +(m[6]||0));
  }
  const d = new Date(s);
  return isNaN(d) ? null : d;
}

function makeBorder(colorHex, style) {
  const b = { style: style||'thin', color: { rgb: colorHex } };
  return { top: b, bottom: b, left: b, right: b };
}

// exportXlsx agora abre o modal de cor
