<script>
/* ══ THEME ══ */
const html=document.documentElement;
const themeToggle=document.getElementById('themeToggle');
const themeLabel=document.getElementById('themeLabel');
function setTheme(t){html.setAttribute('data-theme',t);themeLabel.textContent=t==='dark'?'Escuro':'Claro';localStorage.setItem('tlp-theme',t);}
const saved=localStorage.getItem('tlp-theme');
if(saved)setTheme(saved);else if(window.matchMedia('(prefers-color-scheme: dark)').matches)setTheme('dark');
themeToggle.addEventListener('click',()=>setTheme(html.getAttribute('data-theme')==='dark'?'light':'dark'));

/* ══ SHIFT CLOCK ══ */
function updateShift(){const now=new Date(),h=now.getHours(),m=String(now.getMinutes()).padStart(2,'0');const night=h>=15||h<7;document.getElementById('shiftLabel').textContent=night?'🌙 Noturno':'☀️ Diurno';document.getElementById('shiftClock').textContent=`${h}:${m}`;}
updateShift();setInterval(updateShift,30000);

/* ══ TOAST ══ */
function toast(msg,type='ok'){const el=document.getElementById('toast');document.getElementById('toastIcon').textContent=type==='ok'?'✓':'✕';document.getElementById('toastMsg').textContent=msg;el.className=`toast ${type}`;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),4000);}

/* ══ ALERTS ══ */
function showAlert(type,msg){const id=type==='success'?'alertSuccess':'alertError';const tid=type==='success'?'alertSuccessText':'alertErrorText';document.getElementById(tid).textContent=msg;document.getElementById(id).classList.add('active');toast(msg,type==='success'?'ok':'err');setTimeout(()=>document.getElementById(id).classList.remove('active'),6000);}

/* ══ REC COLUMNS ══ */
const REC=['numero de ordem','titulo do alarme','fim sla','end id','ne id','tipo da falha','faixa priorizacao dispatching','estado','regra usuario criador'];
const norm=t=>t.toString().toLowerCase().trim().replace(/\s+/g,' ').replace(/[_-]/g,' ').normalize('NFD').replace(/[\u0300-\u036f]/g,'');
const isRec=h=>REC.some(r=>norm(r)===norm(h));

/* ══ STATE ══ */
let allData=[],headers=[],neIdColIndex=-1;
let selected=new Set();
let sitesForaSet=new Set();
let regraColIndex=-1;

// regraIncludeSet: values that ARE included. If size === allRegraValues.length → all included
let regraIncludeSet=new Set();
let allRegraValues=[]; // [{value, count}]

let fileName='';

// Modal state
let modalShowOnlyFora=false;
let modalShowOnlySelected=false;
let modalSearchQuery='';

/* ══ NE ID DETECT ══ */
const endIdFmtCol=/^[A-Z]{4,8}_\d{3,6}$/i;
const neIdValuePattern=/^(?:[A-Z0-9]{1,10}-[A-Z0-9]{2,12}(?:[_-][A-Z0-9]+)*|[A-Z]{1,4}\d{3,6}|\d{1,2}[A-Z]{2,8}\d{2,6}|[A-Z]{3,10}\d{2,6})$/i;
function isNeIdValue(v){const s=String(v||'').trim();if(s.length<4||s.length>20)return false;if(endIdFmtCol.test(s))return false;return neIdValuePattern.test(s);}
const normHdr=t=>String(t).toLowerCase().trim().replace(/[\s_\-]+/g,'').normalize('NFD').replace(/[\u0300-\u036f]/g,'');
const NE_ID_HDR_NAMES=['neid','site','neidentifier','nodeelement','ne'];
const END_ID_HDR_NAMES=['endid','end_id','enodebid','nodeid'];
function detectNeIdColumn(hdrs){const sample=allData.slice(1,21);for(let i=0;i<hdrs.length;i++){if(NE_ID_HDR_NAMES.includes(normHdr(hdrs[i])))return i;}let best=-1,bestScore=0;for(let i=0;i<hdrs.length;i++){if(END_ID_HDR_NAMES.includes(normHdr(hdrs[i])))continue;let neHits=0,endHits=0;for(const row of sample){const v=String(row[i]||'').trim();if(endIdFmtCol.test(v))endHits++;else if(isNeIdValue(v))neHits++;}if(endHits>neHits)continue;if(neHits>bestScore){bestScore=neHits;best=i;}}return bestScore>=2?best:-1;}

/* ══ DETECT REGRA COLUMN ══ */
function detectRegraColumn(hdrs){const candidates=['regra usuario criador','regra usuário criador','regrausuariocriador','regra criador','usuariocriador'];for(let i=0;i<hdrs.length;i++){if(candidates.some(c=>norm(c)===norm(hdrs[i])))return i;}return -1;}

/* ══ PARSE SITES FORA ══ */
const neIdPattern=/\b(?:[A-Z0-9]{1,10}-[A-Z0-9]{2,12}(?:[_-][A-Z0-9]+)*|[A-Z]{2,8}\d{2,6}|\d{1,2}[A-Z]{2,8}\d{2,6})\b/gi;
function parseSitesFora(){
  const txt=document.getElementById('sitesForaInput').value;
  if(!txt.trim()){showAlert('error','Cole os dados de sites fora primeiro!');return;}
  const matches=txt.match(neIdPattern)||[];
  const blocklist=['SITE','FORA','FILA','DATA','HORA','STATUS','TURNO','TLP','HUB','ANF','EVE','TSK','CRQ','SLA','HW','SW','MW','AC','RF','OK','TX','ID','C1','C2','C3','C4'];
  const endIdFmt=/^[A-Z]{4,8}_\d{3,6}$/i;
  const filtered=matches.filter(m=>{const u=m.trim().toUpperCase();return u.length>=4&&!blocklist.includes(u)&&!endIdFmt.test(u);});
  sitesForaSet=new Set(filtered.map(m=>m.trim().toUpperCase()));
  renderSitesTags();updateSitesCount();
  if(sitesForaSet.size>0){stepDone('step1');stepActive('step2');showAlert('success',`${sitesForaSet.size} NE IDs detectados como sites fora.`);if(allData.length)updateCross();}
  else showAlert('error','Nenhum NE ID detectado. Verifique o formato.');
}
function renderSitesTags(){const wrap=document.getElementById('sitesTagsWrap');const preview=document.getElementById('sitesPreview');if(sitesForaSet.size===0){preview.style.display='none';return;}preview.style.display='block';wrap.innerHTML=[...sitesForaSet].map(ne=>`<span class="tag" onclick="removeSite('${ne}')" title="Clique para remover">${ne}<span class="tag-x">✕</span></span>`).join('');}
function removeSite(ne){sitesForaSet.delete(ne);renderSitesTags();updateSitesCount();if(allData.length)updateCross();}
function updateSitesCount(){const el=document.getElementById('sitesCount');if(sitesForaSet.size>0){el.textContent=`${sitesForaSet.size} NE IDs`;el.style.display='';}else{el.style.display='none';}document.getElementById('sitesForaCount').textContent=sitesForaSet.size;}

document.getElementById('btnParseSites').addEventListener('click',parseSitesFora);
document.getElementById('btnClearSites').addEventListener('click',()=>{document.getElementById('sitesForaInput').value='';sitesForaSet.clear();renderSitesTags();updateSitesCount();if(allData.length)updateCross();});

/* ══ STEPS ══ */
function stepDone(id){const el=document.getElementById(id);el.classList.remove('active');el.classList.add('done');}
function stepActive(id){document.getElementById(id).classList.add('active');}

/* ══ FILE UPLOAD ══ */
const fileInput=document.getElementById('fileInput');
const uploadZone=document.getElementById('uploadZone');
const fileStatus=document.getElementById('fileStatus');
const loading=document.getElementById('loading');
uploadZone.addEventListener('dragover',e=>{e.preventDefault();uploadZone.classList.add('dragover');});
uploadZone.addEventListener('dragleave',()=>uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop',e=>{e.preventDefault();uploadZone.classList.remove('dragover');if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);});
fileInput.addEventListener('change',e=>{if(e.target.files[0])handleFile(e.target.files[0]);});

function handleFile(file){
  if(!file.name.match(/\.(xlsx|xls)$/i)){showAlert('error','Selecione um arquivo Excel válido (.xlsx ou .xls)');return;}
  fileName=file.name;
  fileStatus.innerHTML=`📄 ${file.name} · ${fmtSize(file.size)}`;
  fileStatus.classList.add('active');
  document.getElementById('loadingText').textContent='Processando arquivo...';
  loading.classList.add('active');
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const wb=XLSX.read(e.target.result,{type:'binary',cellDates:true});
      const ws=wb.Sheets[wb.SheetNames[0]];
      allData=XLSX.utils.sheet_to_json(ws,{header:1,defval:'',blankrows:false});
      if(!allData.length){showAlert('error','Arquivo vazio!');loading.classList.remove('active');return;}
      headers=allData[0].map((h,i)=>h||`Coluna ${i+1}`);
      neIdColIndex=detectNeIdColumn(headers);
      regraColIndex=detectRegraColumn(headers);
      regraIncludeSet=new Set();
      allRegraValues=[];
      buildColumns();
      loading.classList.remove('active');
      const neMsg=neIdColIndex>=0?` · NE ID: "${headers[neIdColIndex]}"`:' · ⚠ Coluna NE ID não detectada';
      showAlert('success',`${allData.length-1} registros carregados.${neMsg}`);
      stepDone('step2');stepActive('step3');
    }catch(err){loading.classList.remove('active');showAlert('error','Erro ao processar: '+err.message);}
  };
  reader.onerror=()=>{loading.classList.remove('active');showAlert('error','Erro ao ler o arquivo');};
  reader.readAsBinaryString(file);
}

/* ══ BUILD COLUMNS ══ */
function buildColumns(){
  const rows=allData.slice(1);
  document.getElementById('totalColumns').textContent=headers.length;
  document.getElementById('totalRows').textContent=rows.length;
  selected.clear();
  const colGrid=document.getElementById('colGrid');
  colGrid.innerHTML='';
  headers.forEach((h,i)=>{
    const rec=isRec(h);const isNeId=i===neIdColIndex;
    const item=document.createElement('div');
    item.className='col-item'+(rec?' rec':'');
    const badges=(rec?`<span class="badge-rec">⭐ rec</span>`:'')+( isNeId?`<span class="badge-neid">NE ID</span>`:'');
    item.innerHTML=`<label class="col-label"><input type="checkbox" data-i="${i}"><span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;">${h}</span>${badges}</label>`;
    const cb=item.querySelector('input');
    cb.addEventListener('change',()=>{if(cb.checked){selected.add(i);item.classList.add('selected');}else{selected.delete(i);item.classList.remove('selected');}syncCount();updatePreview();});
    item.addEventListener('click',e=>{if(e.target.tagName!=='INPUT'){cb.checked=!cb.checked;cb.dispatchEvent(new Event('change'));}});
    colGrid.appendChild(item);
  });
  document.getElementById('columnsSection').classList.add('active');
  buildRegraFilter();
  updateCross();
  document.getElementById('openFullPreviewBtn').disabled=false;
}

/* ══════════════════════════════════════════════
   REGRA FILTER — CHECKBOX LOGIC
══════════════════════════════════════════════ */

function getRegraValueCounts(){
  const rows=allData.slice(1);
  const counts={};
  rows.forEach(row=>{
    const v=String(row[regraColIndex]||'').trim();
    if(v) counts[v]=(counts[v]||0)+1;
  });
  return Object.entries(counts).sort((a,b)=>b[1]-a[1]).map(([value,count])=>({value,count}));
}

function buildRegraFilter(){
  const wrap=document.getElementById('regraFilterWrap');
  if(regraColIndex<0){wrap.style.display='none';return;}
  wrap.style.display='block';

  // Initialize: ALL values included
  allRegraValues=getRegraValueCounts();
  regraIncludeSet=new Set(allRegraValues.map(x=>x.value));

  renderRegraList('');
  updateRegraSummary();
  updateRegraHeaderBadge();
}

function renderRegraList(query){
  const container=document.getElementById('regraList');
  const q=query.toLowerCase();
  const filtered=q?allRegraValues.filter(x=>x.value.toLowerCase().includes(q)):allRegraValues;

  if(!filtered.length){
    container.innerHTML=`<div class="regra-empty">Nenhuma regra encontrada para "${escHtml(query)}"</div>`;
    return;
  }

  container.innerHTML=filtered.map(({value,count})=>{
    const included=regraIncludeSet.has(value);
    const cls=included?'regra-cb-item':'regra-cb-item excluded';
    return `<div class="${cls}" onclick="toggleRegraItem(this,'${escAttr(value)}')">
      <div class="regra-cb-checkbox">
        <input type="checkbox"${included?' checked':''} onclick="event.stopPropagation();toggleRegraItem(this.parentElement.parentElement,'${escAttr(value)}')">
      </div>
      <div class="regra-cb-content">
        <span class="regra-cb-name" title="${escHtml(value)}">${escHtml(value)}</span>
        <span class="regra-cb-count">${count} linhas</span>
        <span class="regra-excl-tag">✕ excluída</span>
      </div>
    </div>`;
  }).join('');
}

function toggleRegraItem(itemEl,value){
  const cb=itemEl.querySelector('input[type="checkbox"]');
  if(regraIncludeSet.has(value)){
    regraIncludeSet.delete(value);
    itemEl.classList.add('excluded');
    if(cb) cb.checked=false;
  } else {
    regraIncludeSet.add(value);
    itemEl.classList.remove('excluded');
    if(cb) cb.checked=true;
  }
  updateRegraSummary();
  updateRegraHeaderBadge();
  updateCross();
  updatePreview();
}

function updateRegraSummary(){
  const total=allRegraValues.length;
  const inclCount=regraIncludeSet.size;
  const exclCount=total-inclCount;

  document.getElementById('rsTotal').textContent=total;
  document.getElementById('rsIncl').textContent=inclCount;
  document.getElementById('rsExcl').textContent=exclCount;

  // count how many rows are excluded by regra filter
  const exclRows=allData.slice(1).filter(row=>{
    const v=String(row[regraColIndex]||'').trim();
    return v && !regraIncludeSet.has(v);
  }).length;
  const inclRows=allData.slice(1).length-exclRows;

  document.getElementById('rsExclRows').textContent=exclRows>0?` (${exclRows} linhas removidas)`:'';
  document.getElementById('rsRowsAfter').textContent=inclRows;

  // highlight wrap if exclusions active
  const wrap=document.getElementById('regraFilterWrap');
  wrap.classList.toggle('has-exclusions',exclCount>0);
}

function updateRegraHeaderBadge(){
  const total=allRegraValues.length;
  const exclCount=total-regraIncludeSet.size;
  const badgeEl=document.getElementById('regraHeaderBadge');
  const hintEl=document.getElementById('regraHeaderHint');

  if(exclCount===0){
    badgeEl.innerHTML='<span class="regra-ok-badge">✓ Todas incluídas</span>';
    hintEl.textContent='';
  } else {
    badgeEl.innerHTML=`<span class="regra-excl-badge">✕ ${exclCount} excluída${exclCount>1?'s':''}</span>`;
    const exclRows=allData.slice(1).filter(row=>{
      const v=String(row[regraColIndex]||'').trim();
      return v && !regraIncludeSet.has(v);
    }).length;
    hintEl.textContent=`${exclRows} linhas removidas da exportação`;
  }
}

// collapse/expand
document.getElementById('regraFilterHeader').addEventListener('click',()=>{
  const body=document.getElementById('regraFilterBody');
  const chevron=document.getElementById('regraChevron');
  const open=body.classList.toggle('open');
  chevron.classList.toggle('open',open);
});

// search
document.getElementById('regraSearchInput').addEventListener('input',e=>{
  renderRegraList(e.target.value);
});

// select / deselect all
document.getElementById('regraSelectAll').addEventListener('click',()=>{
  regraIncludeSet=new Set(allRegraValues.map(x=>x.value));
  renderRegraList(document.getElementById('regraSearchInput').value);
  updateRegraSummary();
  updateRegraHeaderBadge();
  updateCross();
  updatePreview();
  toast('Todas as regras incluídas','ok');
});

document.getElementById('regraDeselectAll').addEventListener('click',()=>{
  regraIncludeSet=new Set();
  renderRegraList(document.getElementById('regraSearchInput').value);
  updateRegraSummary();
  updateRegraHeaderBadge();
  updateCross();
  updatePreview();
  toast('Todas as regras excluídas — nenhuma linha será exportada','err');
});

/* ══ CROSS DATA ══ */
function isLinhaFora(row){
  if(neIdColIndex<0||sitesForaSet.size===0)return false;
  return sitesForaSet.has(String(row[neIdColIndex]||'').trim().toUpperCase());
}

function isLinhaRegraOk(row){
  if(regraColIndex<0)return true;
  // If ALL values are included (no filter active), show all
  if(regraIncludeSet.size>=allRegraValues.length)return true;
  const v=String(row[regraColIndex]||'').trim();
  if(!v) return true; // rows with no regra value pass through
  return regraIncludeSet.has(v);
}

function buildAlarmesValue(row){
  if(neIdColIndex<0)return '';
  const ne=String(row[neIdColIndex]||'').trim();
  return ne?`${ne} alarmes`:'';
}

function getFilteredRows(){
  return allData.slice(1).filter(row=>isLinhaRegraOk(row));
}

function updateCross(){
  if(!allData.length)return;
  const rows=getFilteredRows();
  let count=0;
  rows.forEach(row=>{if(isLinhaFora(row))count++;});
  document.getElementById('linhasSinalizadas').textContent=count;
  document.getElementById('sitesForaCount').textContent=sitesForaSet.size;
  document.getElementById('totalRows').textContent=rows.length;

  const ci=document.getElementById('crossInfo');
  if(neIdColIndex>=0&&sitesForaSet.size>0){ci.textContent=`✓ Cruzando via "${headers[neIdColIndex]}" · ${count} linhas sinalizadas`;ci.className='cross-info danger';}
  else if(neIdColIndex<0){ci.textContent='⚠ Coluna NE ID não detectada';ci.className='cross-info warn';}
  else{ci.textContent=`Coluna NE ID: "${headers[neIdColIndex]}" — cole os NE IDs para cruzar`;ci.className='cross-info';}
  updatePreview();
}

function syncCount(){
  document.getElementById('selectedColumns').textContent=selected.size;
  document.getElementById('exportBtn').disabled=selected.size===0;
  if(selected.size>0){stepDone('step3');stepActive('step4');}
  else{const s3=document.getElementById('step3');s3.classList.remove('done');s3.classList.add('active');document.getElementById('step4').classList.remove('active');}
}

/* ══ PREVIEW (small) ══ */
function updatePreview(){
  const si=Array.from(selected).sort((a,b)=>a-b);
  if(!si.length){document.getElementById('previewSection').classList.remove('active');return;}
  document.getElementById('previewHead').innerHTML=`<tr>${si.map((idx,i)=>`<th class="${i===0?'th-accent':''}">${headers[idx]}</th>`).join('')}<th></th><th class="th-danger">STATUS SITE</th><th class="th-amber">ALARMES</th></tr>`;
  const rows=getFilteredRows().slice(0,15);
  document.getElementById('previewBody').innerHTML=rows.map(row=>{
    const fora=isLinhaFora(row);
    return `<tr class="${fora?'row-out':''}">${si.map(idx=>`<td>${row[idx]??''}</td>`).join('')}<td></td><td>${fora?'<span class="badge-fora">● SITE FORA</span>':'<span class="badge-ok">● OK</span>'}</td><td class="alarm-cell">${buildAlarmesValue(row)}</td></tr>`;
  }).join('');
  document.getElementById('previewSection').classList.add('active');
}

/* ══ TOOLBAR ══ */
document.getElementById('searchBox').addEventListener('input',e=>{
  const q=e.target.value.toLowerCase();
  document.getElementById('colGrid').querySelectorAll('.col-item').forEach(item=>{item.style.display=item.textContent.toLowerCase().includes(q)?'':'none';});
});
document.getElementById('selectAllBtn').addEventListener('click',()=>{document.getElementById('colGrid').querySelectorAll('input[type=checkbox]').forEach(cb=>{if(cb.parentElement.parentElement.style.display!=='none'){cb.checked=true;cb.dispatchEvent(new Event('change'));}});});
document.getElementById('deselectAllBtn').addEventListener('click',()=>{document.getElementById('colGrid').querySelectorAll('input[type=checkbox]').forEach(cb=>{cb.checked=false;cb.dispatchEvent(new Event('change'));});});
document.getElementById('recommendedBtn').addEventListener('click',()=>{
  document.getElementById('colGrid').querySelectorAll('input[type=checkbox]').forEach(cb=>{cb.checked=false;cb.parentElement.parentElement.classList.remove('selected');});
  selected.clear();let found=0;
  headers.forEach((h,i)=>{if(isRec(h)){const cb=document.getElementById('colGrid').querySelector(`input[data-i="${i}"]`);if(cb){cb.checked=true;cb.parentElement.parentElement.classList.add('selected');selected.add(i);found++;}}});
  if(neIdColIndex>=0&&!selected.has(neIdColIndex)){const cb=document.getElementById('colGrid').querySelector(`input[data-i="${neIdColIndex}"]`);if(cb){cb.checked=true;cb.parentElement.parentElement.classList.add('selected');selected.add(neIdColIndex);found++;}}
  syncCount();updatePreview();
  if(found>0)showAlert('success',`${found} colunas recomendadas selecionadas.`);
  else showAlert('error','Nenhuma coluna recomendada encontrada na planilha.');
});

/* ══ FULL PREVIEW MODAL ══ */
document.getElementById('openFullPreviewBtn').addEventListener('click',openModal);
document.getElementById('modalClose').addEventListener('click',closeModal);
document.getElementById('modalCloseFooter').addEventListener('click',closeModal);
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

function openModal(){
  document.getElementById('modalOverlay').classList.add('open');
  document.getElementById('modalFileName').textContent=fileName?`· ${fileName}`:'';
  modalShowOnlyFora=false;modalShowOnlySelected=false;modalSearchQuery='';
  document.getElementById('modalSearch').value='';
  document.getElementById('modalToggleFora').classList.remove('btn-primary');
  document.getElementById('modalToggleSelected').classList.remove('btn-primary');
  renderFullTable();
}
function closeModal(){document.getElementById('modalOverlay').classList.remove('open');}

document.getElementById('modalToggleFora').addEventListener('click',function(){
  modalShowOnlyFora=!modalShowOnlyFora;
  this.classList.toggle('btn-primary',modalShowOnlyFora);
  renderFullTable();
});
document.getElementById('modalToggleSelected').addEventListener('click',function(){
  modalShowOnlySelected=!modalShowOnlySelected;
  this.classList.toggle('btn-primary',modalShowOnlySelected);
  renderFullTable();
});
document.getElementById('modalSearch').addEventListener('input',e=>{
  modalSearchQuery=e.target.value.toLowerCase();
  renderFullTable();
});

function renderFullTable(){
  if(!allData.length)return;
  const si=modalShowOnlySelected&&selected.size>0?Array.from(selected).sort((a,b)=>a-b):headers.map((_,i)=>i);

  const thead=document.getElementById('fullTableHead');
  thead.innerHTML=`<tr>
    <th style="width:36px;text-align:right;">#</th>
    ${si.map(i=>{
      const isNeid=i===neIdColIndex;const isRegra=i===regraColIndex;const isSel=selected.has(i);
      const cls=isNeid?'col-selected-hdr':isRegra?'col-regra-hdr':isSel?'col-selected-hdr':'';
      return `<th class="${cls}" title="${headers[i]}">${headers[i]}${isSel&&!modalShowOnlySelected?' ⊞':''}</th>`;
    }).join('')}
    <th class="col-status-hdr">STATUS SITE</th>
  </tr>`;

  let rows=getFilteredRows();
  if(modalShowOnlyFora)rows=rows.filter(r=>isLinhaFora(r));

  const totalAll=allData.slice(1).length;
  const totalFora=allData.slice(1).filter(r=>isLinhaFora(r)).length;
  const totalOk=totalAll-totalFora;
  document.getElementById('ms-total').textContent=totalAll;
  document.getElementById('ms-fora').textContent=totalFora;
  document.getElementById('ms-ok').textContent=totalOk;

  const exclCount=allRegraValues.length - regraIncludeSet.size;
  document.getElementById('ms-regra').textContent=exclCount===0?'Tudo':`${exclCount} excluída(s)`;

  if(modalSearchQuery){
    rows=rows.filter(row=>si.some(i=>{
      const v=String(row[i]||'').toLowerCase();
      return v.includes(modalSearchQuery);
    }));
  }

  document.getElementById('ms-showing').textContent=rows.length;
  document.getElementById('mf-count').textContent=rows.length;
  document.getElementById('mf-total').textContent=totalAll;

  const tbody=document.getElementById('fullTableBody');
  if(rows.length===0){tbody.innerHTML=`<tr><td colspan="${si.length+2}" class="no-results">Nenhum registro encontrado com os filtros atuais.</td></tr>`;return;}

  const RENDER_LIMIT=500;
  const toRender=rows.slice(0,RENDER_LIMIT);

  tbody.innerHTML=toRender.map((row,idx)=>{
    const fora=isLinhaFora(row);
    const rowClass=fora?'row-fora':'';
    const tds=si.map(i=>{
      let val=String(row[i]??'');
      const isNeid=i===neIdColIndex;
      const cellClass=isNeid?(fora?'cell-ne-fora':'cell-ne-ok'):'';
      if(modalSearchQuery&&val.toLowerCase().includes(modalSearchQuery)){
        const re=new RegExp(`(${escRegex(modalSearchQuery)})`,'gi');
        val=val.replace(re,'<mark class="highlight-match">$1</mark>');
      }
      return `<td class="${cellClass}" title="${String(row[i]??'')}">${val}</td>`;
    }).join('');
    const statusPill=fora?'<span class="status-pill-fora">● FORA</span>':'<span class="status-pill-ok">● OK</span>';
    return `<tr class="${rowClass}"><td class="row-num">${idx+1}</td>${tds}<td>${statusPill}</td></tr>`;
  }).join('');

  if(rows.length>RENDER_LIMIT){
    const extra=document.createElement('tr');
    extra.innerHTML=`<td colspan="${si.length+2}" style="text-align:center;padding:1rem;font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--amber);">⚠ Exibindo ${RENDER_LIMIT} de ${rows.length} registros — use a busca para filtrar</td>`;
    tbody.appendChild(extra);
  }
}

/* ══ EXPORT ══ */
document.getElementById('exportBtn').addEventListener('click',doExport);
document.getElementById('modalExportBtn').addEventListener('click',doExport);

function doExport(){
  if(!selected.size){showAlert('error','Selecione ao menos uma coluna!');return;}
  try{
    document.getElementById('loadingText').textContent='Gerando planilha com cruzamento...';
    loading.classList.add('active');
    const si=Array.from(selected).sort((a,b)=>a-b);
    const dataRows=getFilteredRows();

    const statusEmptyColIdx=si.length;const statusColIdx=si.length+1;const alarmesColIdx=si.length+2;const totalCols=si.length+3;

    const sHdr={fill:{patternType:'solid',fgColor:{rgb:'1E2B5E'}},font:{bold:true,color:{rgb:'FFFFFF'},sz:11,name:'Calibri'},alignment:{horizontal:'center',vertical:'center',wrapText:true},border:{top:{style:'medium',color:{rgb:'3B5BFF'}},bottom:{style:'medium',color:{rgb:'3B5BFF'}},left:{style:'thin',color:{rgb:'3B5BFF'}},right:{style:'thin',color:{rgb:'3B5BFF'}}}};
    const sHdrAlarm={fill:{patternType:'solid',fgColor:{rgb:'2D1E00'}},font:{bold:true,color:{rgb:'F5A623'},sz:11,name:'Calibri'},alignment:{horizontal:'center',vertical:'center',wrapText:true},border:{top:{style:'medium',color:{rgb:'F5A623'}},bottom:{style:'medium',color:{rgb:'F5A623'}},left:{style:'thin',color:{rgb:'F5A623'}},right:{style:'thin',color:{rgb:'F5A623'}}}};
    const sFora={fill:{patternType:'solid',fgColor:{rgb:'FF3F5C'}},font:{bold:true,color:{rgb:'FFFFFF'},sz:10,name:'Calibri'},alignment:{vertical:'center'},border:{top:{style:'thin',color:{rgb:'CC0020'}},bottom:{style:'thin',color:{rgb:'CC0020'}},left:{style:'thin',color:{rgb:'CC0020'}},right:{style:'thin',color:{rgb:'CC0020'}}}};
    const sOk={fill:{patternType:'solid',fgColor:{rgb:'FFFFFF'}},font:{color:{rgb:'333333'},sz:10,name:'Calibri'},alignment:{vertical:'center'},border:{top:{style:'thin',color:{rgb:'E2E5F0'}},bottom:{style:'thin',color:{rgb:'E2E5F0'}},left:{style:'thin',color:{rgb:'E2E5F0'}},right:{style:'thin',color:{rgb:'E2E5F0'}}}};
    const sStatusFora={fill:{patternType:'solid',fgColor:{rgb:'CC0020'}},font:{bold:true,color:{rgb:'FFFFFF'},sz:11,name:'Calibri'},alignment:{horizontal:'center',vertical:'center'},border:{top:{style:'medium',color:{rgb:'880015'}},bottom:{style:'medium',color:{rgb:'880015'}},left:{style:'medium',color:{rgb:'880015'}},right:{style:'medium',color:{rgb:'880015'}}}};
    const sStatusOk={fill:{patternType:'solid',fgColor:{rgb:'00C48C'}},font:{bold:true,color:{rgb:'FFFFFF'},sz:11,name:'Calibri'},alignment:{horizontal:'center',vertical:'center'},border:{top:{style:'thin',color:{rgb:'009068'}},bottom:{style:'thin',color:{rgb:'009068'}},left:{style:'thin',color:{rgb:'009068'}},right:{style:'thin',color:{rgb:'009068'}}}};
    const sAlarm={fill:{patternType:'solid',fgColor:{rgb:'FFF8EE'}},font:{italic:true,color:{rgb:'B87A00'},sz:10,name:'Calibri'},alignment:{vertical:'center'},border:{top:{style:'thin',color:{rgb:'E8D090'}},bottom:{style:'thin',color:{rgb:'E8D090'}},left:{style:'thin',color:{rgb:'E8D090'}},right:{style:'thin',color:{rgb:'E8D090'}}}};
    const sAlarmFora={fill:{patternType:'solid',fgColor:{rgb:'4A0010'}},font:{italic:true,bold:true,color:{rgb:'FFC0A0'},sz:10,name:'Calibri'},alignment:{vertical:'center'},border:{top:{style:'thin',color:{rgb:'880030'}},bottom:{style:'thin',color:{rgb:'880030'}},left:{style:'thin',color:{rgb:'880030'}},right:{style:'thin',color:{rgb:'880030'}}}};

    const ws={};
    const hdrLabels=[...si.map(i=>headers[i]),'STATUS','STATUS SITE','ALARMES'];
    hdrLabels.forEach((label,c)=>{ws[XLSX.utils.encode_cell({r:0,c})]={v:label,t:'s',s:c===alarmesColIdx?sHdrAlarm:sHdr};});

    let sitesForaCount=0;
    dataRows.forEach((row,ri)=>{
      const r=ri+1;const fora=isLinhaFora(row);if(fora)sitesForaCount++;
      const estilo=fora?sFora:sOk;
      si.forEach((colIdx,c)=>{const raw=row[colIdx];const isNum=raw!==''&&raw!==null&&raw!==undefined&&!isNaN(raw)&&String(raw).trim()!=='';ws[XLSX.utils.encode_cell({r,c})]={v:raw===undefined||raw===null?'':raw,t:isNum?'n':'s',s:estilo};});
      ws[XLSX.utils.encode_cell({r,c:statusEmptyColIdx})]={v:'',t:'s',s:sOk};
      ws[XLSX.utils.encode_cell({r,c:statusColIdx})]={v:fora?'SITE FORA':'OK',t:'s',s:fora?sStatusFora:sStatusOk};
      ws[XLSX.utils.encode_cell({r,c:alarmesColIdx})]={v:buildAlarmesValue(row),t:'s',s:fora?sAlarmFora:sAlarm};
    });

    ws['!ref']=XLSX.utils.encode_range({s:{r:0,c:0},e:{r:dataRows.length,c:totalCols-1}});
    ws['!cols']=[...si.map(()=>({wch:22})),{wch:14},{wch:20},{wch:28}];
    ws['!rows']=[{hpt:22},...dataRows.map(row=>({hpt:isLinhaFora(row)?18:15}))];

    const wb={SheetNames:['Filas TLP'],Sheets:{'Filas TLP':ws}};

    // summary sheet
    const exclCount=allRegraValues.length-regraIncludeSet.size;
    const regraInfo=exclCount>0
      ?[['',''],['Filtro Regra Usuário','ATIVO'],['Regras incluídas',regraIncludeSet.size],['Regras excluídas',exclCount],...[...allRegraValues.filter(x=>!regraIncludeSet.has(x.value))].map(({value,count})=>[`  Excluída: ${value}`,`${count} linhas removidas`])]
      :[['',''],['Filtro Regra Usuário','Todas incluídas']];
    const sumRows=[['RELATÓRIO DE CRUZAMENTO — TLP',''],['',''],['Data de Geração',new Date().toLocaleString('pt-BR')],['Total de Registros (exportados)',dataRows.length],['Sites Fora (sinalizados)',sitesForaCount],['Sites OK',dataRows.length-sitesForaCount],['NE IDs na lista',sitesForaSet.size],...regraInfo,['',''],['NE ID','STATUS'],...[...sitesForaSet].map(ne=>[ne,'FORA'])];
    const wsSummary={};
    sumRows.forEach((row,r)=>{row.forEach((val,c)=>{const isFoRow=r>=9+regraInfo.length&&c===1&&val==='FORA';wsSummary[XLSX.utils.encode_cell({r,c})]={v:val,t:typeof val==='number'?'n':'s',s:isFoRow?sStatusFora:r===0?sHdr:sOk};});});
    wsSummary['!ref']=XLSX.utils.encode_range({s:{r:0,c:0},e:{r:sumRows.length-1,c:1}});
    wsSummary['!cols']=[{wch:40},{wch:20}];
    wb.SheetNames.push('Resumo');wb.Sheets['Resumo']=wsSummary;

    const ts=new Date().toISOString().slice(0,19).replace(/:/g,'-');
    XLSX.writeFile(wb,`TLP_Filas_Cruzado_${ts}.xlsx`,{bookType:'xlsx',type:'binary',cellStyles:true});
    loading.classList.remove('active');
    showAlert('success',`Exportado! ${sitesForaCount} sinalizadas · ${dataRows.length-sitesForaCount} OK · ${dataRows.length} registros.`);
  }catch(err){loading.classList.remove('active');showAlert('error','Erro ao exportar: '+err.message);console.error(err);}
}

/* ══ UTILS ══ */
function fmtSize(b){if(!b)return'0 B';const k=1024,s=['B','KB','MB','GB'];const i=Math.floor(Math.log(b)/Math.log(k));return(b/Math.pow(k,i)).toFixed(1)+' '+s[i];}
function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function escAttr(s){return String(s).replace(/'/g,"\\'");}
function escRegex(s){return s.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');}
</script>
