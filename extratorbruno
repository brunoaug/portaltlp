        </div>
        <div class="divider"></div>
        <button class="btn btn-ghost" id="selectAllBtn">✓ Todas</button>
        <button class="btn btn-ghost" id="deselectAllBtn">✕ Nenhuma</button>
        <button class="btn btn-success" id="recommendedBtn">⭐ Recomendadas</button>
        <div class="divider"></div>
        <button class="btn btn-preview-full" id="openFullPreviewBtn" disabled>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
