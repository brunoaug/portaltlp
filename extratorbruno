        <div class="stat-card"><div class="stat-label">Sites Fora</div><div class="stat-value danger" id="sitesForaCount">0</div></div>
        <div class="stat-card"><div class="stat-label">Sinalizadas</div><div class="stat-value danger" id="linhasSinalizadas">0</div></div>
      </div>

      <div class="toolbar">
        <div class="search-box">
