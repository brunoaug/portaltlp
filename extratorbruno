          <div style="display:flex;align-items:center;gap:8px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--muted);" id="regraHeaderHint">Todas incluídas</span>
            <span class="regra-chevron" id="regraChevron">▼</span>
          </div>
