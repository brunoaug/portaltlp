<!DOCTYPE html>
<html lang="pt-BR" data-theme="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TLP · Extrator de Filas</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#F0F2F7;--surface:#FFFFFF;--surface2:#F7F8FC;--surface3:#EEF0F8;
  --border:#E2E5F0;--border2:#CBD0E8;--text:#0F1628;--text2:#4A5280;--muted:#8C93B8;
  --accent:#3B5BFF;--accent-bg:rgba(59,91,255,0.08);--accent-glow:rgba(59,91,255,0.20);
  --green:#00C48C;--green-bg:rgba(0,196,140,0.10);--red:#FF3F5C;--red-bg:rgba(255,63,92,0.10);
  --amber:#F5A623;--amber-bg:rgba(245,166,35,0.10);
  --shadow-sm:0 1px 3px rgba(15,22,40,0.06),0 1px 2px rgba(15,22,40,0.04);
  --shadow-md:0 4px 12px rgba(15,22,40,0.08),0 2px 6px rgba(15,22,40,0.04);
  --shadow-lg:0 12px 36px rgba(15,22,40,0.10),0 4px 12px rgba(15,22,40,0.06);
  --radius-sm:8px;--radius-md:12px;--radius-lg:18px;--radius-xl:24px;
  --transition:0.2s cubic-bezier(0.4,0,0.2,1);
}
[data-theme="dark"] {
  --bg:#0C0F1A;--surface:#131726;--surface2:#1A1F35;--surface3:#222844;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#EDF0FF;--text2:#8B95C9;--muted:#4A5280;
  --accent:#5B7FFF;--accent-bg:rgba(91,127,255,0.12);--accent-glow:rgba(91,127,255,0.25);
  --green:#00E5A6;--green-bg:rgba(0,229,166,0.10);--red:#FF5572;--red-bg:rgba(255,85,114,0.10);
  --amber:#FFB830;--amber-bg:rgba(255,184,48,0.10);
  --shadow-sm:0 1px 3px rgba(0,0,0,0.30);--shadow-md:0 4px 12px rgba(0,0,0,0.40);--shadow-lg:0 12px 36px rgba(0,0,0,0.50);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif;font-size:15px;line-height:1.5;min-height:100vh;transition:background var(--transition),color var(--transition);-webkit-font-smoothing:antialiased;}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:40px 40px;opacity:0.4;}
body>*{position:relative;z-index:1;}
.app-layout{display:grid;grid-template-rows:auto 1fr auto;min-height:100vh;}
header{background:var(--surface);border-bottom:1px solid var(--border);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100;box-shadow:var(--shadow-sm);}
.header-inner{max-width:1280px;margin:0 auto;padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.brand{display:flex;align-items:center;gap:12px;text-decoration:none;color:inherit;}
.brand-icon{width:40px;height:40px;background:var(--accent);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 12px var(--accent-glow);flex-shrink:0;}
.brand-icon svg{width:22px;height:22px;fill:#fff;}
.brand-text{line-height:1.1;}
.brand-name{font-weight:700;font-size:1rem;letter-spacing:-0.02em;color:var(--text);}
.brand-sub{font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;}
.header-actions{display:flex;align-items:center;gap:0.75rem;}
.theme-toggle{width:44px;height:24px;background:var(--surface3);border:1px solid var(--border2);border-radius:100px;position:relative;cursor:pointer;transition:background var(--transition),border-color var(--transition);flex-shrink:0;}
.theme-toggle::after{content:'';position:absolute;top:2px;left:2px;width:18px;height:18px;background:var(--accent);border-radius:50%;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1),background var(--transition);box-shadow:0 1px 4px rgba(0,0,0,0.2);}
[data-theme="dark"] .theme-toggle::after{transform:translateX(20px);}
.theme-label{font-size:0.72rem;font-weight:500;color:var(--muted);font-family:'JetBrains Mono',monospace;user-select:none;cursor:pointer;}
.shift-badge{display:flex;align-items:center;gap:6px;padding:5px 12px;background:var(--surface2);border:1px solid var(--border);border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text2);}
.shift-dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 6px var(--green);flex-shrink:0;animation:pulse 2s ease-in-out infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.6;transform:scale(0.85);}}
main{max-width:1280px;margin:0 auto;padding:2.5rem 2rem 4rem;width:100%;}
.page-hero{margin-bottom:2.5rem;animation:fadeUp 0.5s ease both;}
.page-hero h1{font-size:2rem;font-weight:800;letter-spacing:-0.04em;line-height:1.1;color:var(--text);margin-bottom:0.5rem;}
.page-hero h1 .highlight{background:linear-gradient(135deg,var(--accent) 0%,#8B5CF6 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.page-hero p{font-size:0.88rem;color:var(--text2);max-width:520px;}
.stepper{display:flex;align-items:center;gap:0;margin-bottom:2rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md);padding:0.5rem;box-shadow:var(--shadow-sm);overflow-x:auto;animation:fadeUp 0.5s 0.1s ease both;}
.step{display:flex;align-items:center;gap:8px;padding:8px 14px;border-radius:var(--radius-sm);font-size:0.78rem;font-weight:500;color:var(--muted);transition:all var(--transition);white-space:nowrap;flex-shrink:0;cursor:default;}
.step-num{width:22px;height:22px;border-radius:50%;background:var(--surface3);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:0.65rem;font-weight:600;color:var(--muted);flex-shrink:0;transition:all var(--transition);}
.step.active{background:var(--accent-bg);color:var(--accent);}
.step.active .step-num{background:var(--accent);color:#fff;}
.step.done{color:var(--green);}
.step.done .step-num{background:var(--green-bg);color:var(--green);}
.step.done .step-num::after{content:'✓';}
.step.done .step-num span{display:none;}
.step-sep{width:24px;height:1px;background:var(--border2);flex-shrink:0;margin:0 4px;}
.alerts-wrap{margin-bottom:1.25rem;display:flex;flex-direction:column;gap:0.5rem;}
.alert{display:none;align-items:center;gap:10px;padding:12px 16px;border-radius:var(--radius-sm);font-size:0.8rem;font-weight:500;border:1px solid;animation:slideIn 0.25s ease;}
.alert.active{display:flex;}
@keyframes slideIn{from{opacity:0;transform:translateY(-8px);}to{opacity:1;transform:translateY(0);}}
.alert-icon{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;flex-shrink:0;}
.alert-success{background:var(--green-bg);border-color:rgba(0,196,140,0.3);color:var(--green);}
.alert-success .alert-icon{background:var(--green);color:#fff;}
.alert-error{background:var(--red-bg);border-color:rgba(255,63,92,0.3);color:var(--red);}
.alert-error .alert-icon{background:var(--red);color:#fff;}
.loading{display:none;align-items:center;justify-content:center;gap:10px;padding:14px;font-size:0.8rem;font-weight:500;color:var(--accent);font-family:'JetBrains Mono',monospace;}
.loading.active{display:flex;}
.spinner{width:18px;height:18px;border-radius:50%;border:2px solid var(--accent-bg);border-top-color:var(--accent);animation:spin 0.7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.input-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.5rem;animation:fadeUp 0.5s 0.15s ease both;}
@media(max-width:860px){.input-grid{grid-template-columns:1fr;}}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:1rem;transition:border-color var(--transition),box-shadow var(--transition);}
.card:hover{border-color:var(--border2);box-shadow:var(--shadow-md);}
.card-header{display:flex;align-items:flex-start;gap:12px;}
.card-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem;}
.card-icon.blue{background:var(--accent-bg);}
.card-icon.green{background:var(--green-bg);}
.card-title{font-size:0.9rem;font-weight:700;color:var(--text);}
.card-sub{font-size:0.78rem;color:var(--muted);line-height:1.55;margin-top:2px;}
textarea{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:0.76rem;padding:0.9rem 1rem;resize:vertical;min-height:200px;outline:none;line-height:1.7;transition:border-color var(--transition),background var(--transition);}
textarea:focus{border-color:var(--accent);background:var(--surface);box-shadow:0 0 0 3px var(--accent-glow);}
textarea::placeholder{color:var(--muted);}
.btn-row{display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:var(--radius-sm);border:1px solid transparent;font-family:'Outfit',sans-serif;font-size:0.8rem;font-weight:600;cursor:pointer;transition:all var(--transition);white-space:nowrap;text-decoration:none;}
.btn:disabled{opacity:0.35;cursor:not-allowed;}
.btn-primary{background:var(--accent);color:#fff;border-color:var(--accent);box-shadow:0 2px 8px var(--accent-glow);}
.btn-primary:hover:not(:disabled){filter:brightness(1.08);transform:translateY(-1px);box-shadow:0 4px 16px var(--accent-glow);}
.btn-ghost{background:var(--surface2);color:var(--text2);border-color:var(--border);}
.btn-ghost:hover:not(:disabled){background:var(--surface3);color:var(--text);border-color:var(--border2);}
.btn-success{background:var(--green-bg);color:var(--green);border-color:rgba(0,196,140,0.25);}
.btn-success:hover:not(:disabled){background:rgba(0,196,140,0.18);}
.btn-danger{background:var(--red-bg);color:var(--red);border-color:rgba(255,63,92,0.2);}
.btn-danger:hover:not(:disabled){background:rgba(255,63,92,0.18);}
.btn-export{background:linear-gradient(135deg,var(--accent) 0%,#7C3AED 100%);color:#fff;border:none;box-shadow:0 2px 12px var(--accent-glow);padding:9px 20px;font-size:0.84rem;}
.btn-export:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 6px 20px var(--accent-glow);}
.btn-preview-full{background:linear-gradient(135deg,#0F766E 0%,#0D9488 100%);color:#fff;border:none;box-shadow:0 2px 10px rgba(13,148,136,0.3);padding:9px 20px;font-size:0.84rem;}
.btn-preview-full:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 5px 18px rgba(13,148,136,0.4);}
.count-badge{font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--muted);padding:4px 8px;background:var(--surface3);border-radius:100px;border:1px solid var(--border);}
.sites-preview{display:none;}
.sites-preview-label{font-size:0.72rem;font-weight:600;color:var(--green);font-family:'JetBrains Mono',monospace;margin-bottom:8px;display:flex;align-items:center;gap:6px;}
.tags-wrap{display:flex;flex-wrap:wrap;gap:6px;max-height:120px;overflow-y:auto;}
.tag{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;background:var(--red-bg);border:1px solid rgba(255,63,92,0.25);border-radius:100px;font-family:'JetBrains Mono',monospace;font-size:0.66rem;color:var(--red);cursor:pointer;transition:all var(--transition);}
.tag:hover{background:rgba(255,63,92,0.2);}
.tag-x{font-size:0.6rem;opacity:0.6;}
.upload-zone{border:2px dashed var(--border2);border-radius:var(--radius-md);background:var(--surface2);padding:2rem 1.5rem;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0.9rem;text-align:center;cursor:pointer;flex:1;transition:all var(--transition);}
.upload-zone:hover,.upload-zone.dragover{border-color:var(--accent);background:var(--accent-bg);transform:translateY(-2px);}
.upload-zone.dragover{transform:scale(1.01);}
input[type="file"]{display:none;}
.upload-zone-icon{width:52px;height:52px;border-radius:var(--radius-md);background:var(--surface);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.4rem;box-shadow:var(--shadow-md);animation:float 4s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.upload-title{font-size:0.92rem;font-weight:700;color:var(--text);}
.upload-sub{font-size:0.75rem;color:var(--muted);line-height:1.5;max-width:200px;}
.file-status{font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--muted);display:flex;align-items:center;gap:6px;padding:6px 12px;background:var(--surface3);border-radius:100px;border:1px solid var(--border);}
.file-status.active{color:var(--accent);border-color:var(--accent-glow);background:var(--accent-bg);}
.section{display:none;}
.section.active{display:block;animation:fadeUp 0.4s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}
.stats-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.75rem;margin-bottom:1.5rem;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md);padding:1rem 1.25rem;transition:all var(--transition);}
.stat-card:hover{border-color:var(--border2);transform:translateY(-1px);box-shadow:var(--shadow-md);}
.stat-label{font-size:0.65rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);margin-bottom:6px;font-family:'JetBrains Mono',monospace;}
.stat-value{font-size:1.8rem;font-weight:800;letter-spacing:-0.03em;line-height:1;color:var(--accent);}
.stat-value.danger{color:var(--red);}
.toolbar{display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;padding:0.75rem;margin-bottom:1rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-md);box-shadow:var(--shadow-sm);}
.search-box{flex:1;min-width:160px;display:flex;align-items:center;gap:8px;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 12px;transition:border-color var(--transition);}
.search-box:focus-within{border-color:var(--accent);}
.search-box svg{width:14px;height:14px;fill:none;stroke:var(--muted);stroke-width:2;flex-shrink:0;}
.search-box input{flex:1;background:none;border:none;outline:none;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:0.76rem;}
.search-box input::placeholder{color:var(--muted);}
.divider{width:1px;height:24px;background:var(--border);margin:0 4px;flex-shrink:0;}
.col-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;margin-bottom:1.5rem;}
.col-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);padding:0.7rem 0.9rem;cursor:pointer;transition:all var(--transition);position:relative;overflow:hidden;}
.col-item:hover{border-color:var(--border2);background:var(--surface2);}
.col-item.selected{border-color:var(--accent);background:var(--accent-bg);box-shadow:0 0 0 1px var(--accent);}
.col-item.rec{border-left:3px solid var(--green);}
.col-item.rec.selected{border-color:var(--green);background:var(--green-bg);box-shadow:0 0 0 1px var(--green);}
.col-label{display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--text2);cursor:pointer;user-select:none;line-height:1.4;}
.col-item.selected .col-label{color:var(--text);}
.col-label input[type="checkbox"]{width:15px;height:15px;flex-shrink:0;accent-color:var(--accent);cursor:pointer;border-radius:4px;}
.badge-rec{display:inline-flex;align-items:center;padding:1px 6px;border-radius:100px;font-size:0.6rem;font-weight:600;background:var(--green-bg);color:var(--green);margin-left:auto;flex-shrink:0;}
.badge-neid{display:inline-flex;align-items:center;padding:1px 6px;border-radius:100px;font-size:0.6rem;font-weight:600;background:var(--red-bg);color:var(--red);margin-left:4px;flex-shrink:0;}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;gap:1rem;flex-wrap:wrap;}
.section-title{font-size:1.05rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:10px;}
.section-title .icon{width:32px;height:32px;border-radius:8px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;font-size:0.9rem;}
.cross-info{font-family:'JetBrains Mono',monospace;font-size:0.72rem;padding:5px 12px;border-radius:100px;border:1px solid var(--border);background:var(--surface2);color:var(--muted);}
.cross-info.warn{border-color:rgba(245,166,35,0.4);background:var(--amber-bg);color:var(--amber);}
.cross-info.danger{border-color:rgba(255,63,92,0.3);background:var(--red-bg);color:var(--red);}
.preview-section{display:none;margin-top:1.5rem;}
.preview-section.active{display:block;animation:fadeUp 0.3s ease;}
.preview-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;flex-wrap:wrap;gap:0.75rem;}
.legend{display:flex;gap:1rem;flex-wrap:wrap;align-items:center;}
.leg{display:flex;align-items:center;gap:5px;font-size:0.72rem;color:var(--muted);font-family:'JetBrains Mono',monospace;}
.leg-dot{width:8px;height:8px;border-radius:50%;}
.table-container{border-radius:var(--radius-md);border:1px solid var(--border);overflow:hidden;box-shadow:var(--shadow-md);}
.table-scroll{overflow-x:auto;max-height:360px;}
table{width:100%;border-collapse:collapse;background:var(--surface);}
thead tr{background:var(--surface2);}
th{padding:10px 14px;text-align:left;font-family:'JetBrains Mono',monospace;font-size:0.63rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;position:sticky;top:0;z-index:10;background:var(--surface2);border-bottom:1px solid var(--border2);white-space:nowrap;}
th.th-accent{color:var(--accent);border-bottom-color:var(--accent);}
th.th-danger{color:var(--red);border-bottom-color:var(--red);}
th.th-amber{color:var(--amber);border-bottom-color:var(--amber);}
td{padding:9px 14px;border-bottom:1px solid var(--border);font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--text2);}
tr:last-child td{border-bottom:none;}
tr:hover td{background:var(--surface2);}
tr.row-out td{background:var(--red-bg);color:var(--red);}
tr.row-out:hover td{background:rgba(255,63,92,0.15);}
.badge-ok{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:100px;font-size:0.65rem;font-weight:600;background:var(--green-bg);color:var(--green);}
.badge-fora{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:100px;font-size:0.65rem;font-weight:600;background:var(--red-bg);color:var(--red);}
.alarm-cell{color:var(--amber);font-style:italic;}
.columns-section-wrap{margin-top:1.5rem;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-xl);padding:1.75rem;box-shadow:var(--shadow-sm);}

/* ═══ REGRA FILTER — CHECKBOX STYLE ═══ */
.regra-filter-wrap{
  margin-top:1.25rem;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius-lg);
  overflow:hidden;
  box-shadow:var(--shadow-sm);
  transition:border-color var(--transition),box-shadow var(--transition);
}
.regra-filter-wrap.has-exclusions{
  border-color:rgba(255,63,92,0.4);
  box-shadow:0 0 0 2px rgba(255,63,92,0.08);
}
.regra-filter-header{
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  padding:1rem 1.25rem;
  cursor:pointer;user-select:none;
  transition:background var(--transition);
}
.regra-filter-header:hover{background:var(--surface2);}
.regra-filter-title{
  display:flex;align-items:center;gap:10px;
  font-size:0.88rem;font-weight:700;color:var(--text);
}
.regra-title-icon{
  width:32px;height:32px;border-radius:8px;
  background:rgba(139,92,246,0.12);
  display:flex;align-items:center;justify-content:center;font-size:0.9rem;
}
.regra-excl-badge{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 10px;border-radius:100px;
  font-size:0.65rem;font-weight:700;font-family:'JetBrains Mono',monospace;
  background:var(--red);color:#fff;
  animation:fadeUp 0.2s ease;
}
.regra-ok-badge{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 10px;border-radius:100px;
  font-size:0.65rem;font-weight:600;font-family:'JetBrains Mono',monospace;
  background:var(--green-bg);color:var(--green);border:1px solid rgba(0,196,140,0.25);
}
.regra-chevron{
  font-size:0.7rem;color:var(--muted);
  transition:transform 0.2s ease;font-family:'JetBrains Mono',monospace;
}
.regra-chevron.open{transform:rotate(180deg);}
.regra-filter-body{
  display:none;
  border-top:1px solid var(--border);
}
.regra-filter-body.open{display:block;animation:fadeUp 0.2s ease;}

/* summary bar */
.regra-summary-bar{
  display:flex;align-items:center;gap:1rem;flex-wrap:wrap;
  padding:0.75rem 1.25rem;
  background:var(--surface2);
  border-bottom:1px solid var(--border);
}
.regra-sum-item{
  display:flex;align-items:center;gap:6px;
  font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text2);
}
.regra-sum-item strong{font-weight:700;}
.regra-sum-item.ok strong{color:var(--green);}
.regra-sum-item.excl strong{color:var(--red);}
.regra-sum-item.total strong{color:var(--accent);}
.regra-sum-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.regra-sum-sep{width:1px;height:14px;background:var(--border);flex-shrink:0;}

/* toolbar */
.regra-toolbar{
  display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;
  padding:0.75rem 1.25rem;
  border-bottom:1px solid var(--border);
}
.regra-search-box{
  flex:1;min-width:180px;max-width:320px;
  display:flex;align-items:center;gap:8px;
  background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);
  padding:6px 12px;transition:border-color var(--transition);
}
.regra-search-box:focus-within{border-color:var(--accent);}
.regra-search-box svg{width:13px;height:13px;fill:none;stroke:var(--muted);stroke-width:2;flex-shrink:0;}
.regra-search-box input{flex:1;background:none;border:none;outline:none;color:var(--text);font-family:'JetBrains Mono',monospace;font-size:0.74rem;}
.regra-search-box input::placeholder{color:var(--muted);}
.regra-filter-hint{font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--muted);margin-left:auto;}

/* checkbox list */
.regra-list{
  max-height:280px;overflow-y:auto;
  padding:0.5rem 0;
}
.regra-cb-item{
  display:flex;align-items:center;gap:0;
  padding:0;
  border-bottom:1px solid var(--border);
  transition:background var(--transition);
  cursor:pointer;
}
.regra-cb-item:last-child{border-bottom:none;}
.regra-cb-item:hover{background:var(--surface2);}
.regra-cb-item.excluded{background:var(--red-bg);}
.regra-cb-item.excluded:hover{background:rgba(255,63,92,0.15);}
.regra-cb-checkbox{
  display:flex;align-items:center;justify-content:center;
  width:44px;height:100%;min-height:44px;flex-shrink:0;
}
.regra-cb-checkbox input[type="checkbox"]{
  width:16px;height:16px;
  accent-color:var(--accent);cursor:pointer;
  flex-shrink:0;
}
.regra-cb-content{
  flex:1;min-width:0;
  padding:10px 12px 10px 0;
  display:flex;align-items:center;gap:8px;
}
.regra-cb-name{
  flex:1;min-width:0;
  font-family:'JetBrains Mono',monospace;font-size:0.72rem;
  color:var(--text);
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.regra-cb-item.excluded .regra-cb-name{
  color:var(--red);text-decoration:line-through;text-decoration-color:rgba(255,63,92,0.5);
}
.regra-cb-count{
  display:inline-flex;align-items:center;
  padding:1px 7px;border-radius:100px;
  font-family:'JetBrains Mono',monospace;font-size:0.62rem;font-weight:600;
  background:var(--surface3);color:var(--muted);border:1px solid var(--border);
  flex-shrink:0;
}
.regra-cb-item.excluded .regra-cb-count{
  background:rgba(255,63,92,0.12);color:var(--red);border-color:rgba(255,63,92,0.2);
}
.regra-excl-tag{
  display:inline-flex;align-items:center;gap:3px;
  padding:1px 7px;border-radius:100px;
  font-family:'JetBrains Mono',monospace;font-size:0.6rem;font-weight:700;
  background:var(--red);color:#fff;flex-shrink:0;
}
.regra-cb-item .regra-excl-tag{display:none;}
.regra-cb-item.excluded .regra-excl-tag{display:inline-flex;}

/* empty state */
.regra-empty{
  padding:2rem;text-align:center;
  font-family:'JetBrains Mono',monospace;font-size:0.74rem;color:var(--muted);
}

/* ═══ FULL PREVIEW MODAL ═══ */
.modal-overlay{
  display:none;position:fixed;inset:0;z-index:1000;
  background:rgba(0,0,0,0.55);backdrop-filter:blur(6px);
  animation:fadeOverlay 0.2s ease;
}
.modal-overlay.open{display:flex;align-items:stretch;}
@keyframes fadeOverlay{from{opacity:0;}to{opacity:1;}}
.modal{
  background:var(--surface);border-left:1px solid var(--border);
  width:100%;max-width:100vw;
  display:flex;flex-direction:column;
  animation:slideModal 0.3s cubic-bezier(0.34,1.2,0.64,1);
}
@keyframes slideModal{from{transform:translateY(40px);opacity:0;}to{transform:translateY(0);opacity:1;}}
.modal-header{
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  padding:1rem 1.5rem;
  border-bottom:1px solid var(--border);
  background:var(--surface);
  position:sticky;top:0;z-index:10;
  box-shadow:var(--shadow-sm);
  flex-shrink:0;
}
.modal-title{font-size:1rem;font-weight:700;color:var(--text);display:flex;align-items:center;gap:10px;}
.modal-actions{display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;}
.modal-close{
  width:34px;height:34px;border-radius:50%;
  background:var(--surface2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:1rem;color:var(--text2);
  transition:all var(--transition);
}
.modal-close:hover{background:var(--red-bg);color:var(--red);border-color:rgba(255,63,92,0.3);}
.modal-stats{
  display:flex;gap:1rem;align-items:center;flex-wrap:wrap;
  padding:0.65rem 1.5rem;
  background:var(--surface2);border-bottom:1px solid var(--border);
  flex-shrink:0;
}
.modal-stat{
  display:flex;align-items:center;gap:6px;
  font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--text2);
}
.modal-stat strong{color:var(--text);font-weight:700;}
.modal-stat-sep{width:1px;height:14px;background:var(--border);flex-shrink:0;}
.modal-filter-bar{
  display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap;
  padding:0.65rem 1.5rem;
  border-bottom:1px solid var(--border);
  background:var(--surface);
  flex-shrink:0;
}
.modal-filter-bar .search-box{max-width:260px;}
.modal-body{flex:1;overflow:auto;padding:0;}
.full-table-container{min-height:100%;}
.full-table{width:100%;border-collapse:collapse;}
.full-table thead tr{background:var(--surface2);position:sticky;top:0;z-index:5;}
.full-table th{
  padding:9px 12px;text-align:left;
  font-family:'JetBrains Mono',monospace;font-size:0.6rem;font-weight:600;
  color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;
  background:var(--surface2);border-bottom:2px solid var(--border2);
  white-space:nowrap;cursor:default;
}
.full-table th.col-selected-hdr{color:var(--accent);border-bottom-color:var(--accent);}
.full-table th.col-status-hdr{color:var(--red);border-bottom-color:var(--red);}
.full-table th.col-regra-hdr{color:#8B5CF6;border-bottom-color:#8B5CF6;}
.full-table th.th-sort{cursor:pointer;}
.full-table th.th-sort:hover{color:var(--text);}
.full-table td{
  padding:8px 12px;border-bottom:1px solid var(--border);
  font-family:'JetBrains Mono',monospace;font-size:0.7rem;color:var(--text2);
  max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.full-table tr:hover td{background:var(--surface2);}
.full-table tr.row-fora td{background:rgba(255,63,92,0.06);}
.full-table tr.row-fora:hover td{background:rgba(255,63,92,0.12);}
.full-table .cell-ne-fora{color:var(--red);font-weight:600;}
.full-table .cell-ne-ok{color:var(--green);}
.row-num{color:var(--muted);font-size:0.6rem;text-align:right;width:36px;min-width:36px;border-right:1px solid var(--border);padding-right:8px;}
.status-pill-fora{
  display:inline-flex;align-items:center;gap:3px;
  padding:2px 7px;border-radius:100px;font-size:0.62rem;font-weight:700;
  background:var(--red);color:#fff;white-space:nowrap;
}
.status-pill-ok{
  display:inline-flex;align-items:center;gap:3px;
  padding:2px 7px;border-radius:100px;font-size:0.62rem;font-weight:700;
  background:var(--green-bg);color:var(--green);white-space:nowrap;
}
.no-results{
  padding:3rem;text-align:center;
  font-family:'JetBrains Mono',monospace;font-size:0.8rem;color:var(--muted);
}
.modal-footer{
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  padding:0.75rem 1.5rem;
  border-top:1px solid var(--border);
  background:var(--surface);
  flex-shrink:0;flex-wrap:wrap;
}
.modal-footer-info{font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--muted);}
.modal-footer-info strong{color:var(--text);}
.highlight-match{background:rgba(59,91,255,0.2);border-radius:2px;color:var(--accent);}
footer{border-top:1px solid var(--border);background:var(--surface);}
.footer-inner{max-width:1280px;margin:0 auto;padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;}
.footer-brand{font-weight:700;font-size:0.85rem;color:var(--text);}
.footer-copy{font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:var(--muted);}
.toast{position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;background:var(--surface);border:1px solid var(--border2);border-radius:var(--radius-md);padding:12px 18px;font-size:0.82rem;font-weight:500;color:var(--text);box-shadow:var(--shadow-lg);display:flex;align-items:center;gap:10px;max-width:320px;transform:translateY(100px) scale(0.95);opacity:0;transition:all 0.35s cubic-bezier(0.34,1.56,0.64,1);}
.toast.show{transform:translateY(0) scale(1);opacity:1;}
.toast.ok{border-left:3px solid var(--green);}
.toast.err{border-left:3px solid var(--red);}
.toast-icon{width:24px;height:24px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;}
.toast.ok .toast-icon{background:var(--green);color:#fff;}
.toast.err .toast-icon{background:var(--red);color:#fff;}
@media(max-width:640px){
  .header-inner{padding:0 1rem;}
  main{padding:1.5rem 1rem 3rem;}
  .page-hero h1{font-size:1.5rem;}
  .columns-section-wrap{padding:1.25rem;}
  footer .footer-inner{padding:0.75rem 1rem;}
}
</style>
</head>
<body>
<div class="app-layout">

<header>
  <div class="header-inner">
    <div class="brand">
      <div class="brand-icon">
